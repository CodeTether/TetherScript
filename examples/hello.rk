// rk v0 sample — not runnable yet, just lexable.

fn greet(name) {
    let greeting = "hello, " + name
    println(greeting)
}

fn fib(n) {
    if n < 2 { n } else { fib(n - 1) + fib(n - 2) }
}

fn main() {
    let mut xs = [1, 2, 3]
    xs.push(4)

    let total = fib(10)
    println(total)

    // implicit borrow — xs stays live
    print_all(xs)
    println(xs.len())

    // explicit move — after this, xs is a tombstone
    consume(move xs)
}
