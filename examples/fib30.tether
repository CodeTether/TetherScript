// Benchmark: fib(30) — measures raw recursive call throughput.

fn fib(n) {
    if n < 2 { return n }
    return fib(n - 1) + fib(n - 2)
}

fn main() {
    let start = time_ms()
    let result = fib(30)
    let elapsed = time_ms() - start
    println("fib(30) = " + result)
    println("elapsed: " + elapsed + "ms")
}
