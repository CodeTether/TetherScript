// tetherscript: authority agent
// tetherscript: hot-reload

fn single_line(value) {
    let mut text = str(value)
    text = text.replace("\r\n", "\\n")
    text = text.replace("\n", "\\n")
    return text.replace("\r", "\\n")
}

fn clean_text(value) {
    let mut text = str(value)
    text = text.replace("\r\n", "\n")
    text = text.replace("\r", "\n")
    return text
}

fn item(kind, name, text) {
    let row = map()
    row.kind = kind
    row.name = name
    row.text = clean_text(text)
    if kind == "system" { row.fg = "bright_cyan"; row.bold = true }
    if kind == "user" { row.fg = "bright_white" }
    if kind == "agent" { row.fg = "bright_green" }
    if kind == "tool" { row.fg = "bright_yellow" }
    if kind == "rpc" { row.fg = "bright_magenta" }
    return row
}

fn esc() {
    return b"\x1b".decode_utf8()
}

fn ansi_clear_home() {
    return esc() + "[2J" + esc() + "[H"
}

fn ansi_enter() {
    return esc() + "[?1049h" + esc() + "[?25l" + ansi_clear_home()
}

fn ansi_leave() {
    return esc() + "[0m" + esc() + "[?25h" + esc() + "[?1049l"
}

fn ansi_reset() {
    return esc() + "[0m"
}

fn env_int(name, fallback) {
    let raw = env_get(name).unwrap_or(nil)
    if raw == nil { return fallback }
    let parsed = parse_int(raw)
    if parsed.is_err() { return fallback }
    let value = parsed.unwrap()
    if value <= 0 { return fallback }
    return value
}

fn terminal_size() {
    let size = map()
    size.cols = env_int("COLUMNS", 80)
    size.rows = env_int("LINES", 24)
    return size
}

fn at_least(value, floor) {
    if value < floor { return floor }
    return value
}

fn repeat_text(text, count) {
    let mut out = ""
    let mut i = 0
    while i < count {
        out = out + text
        i = i + 1
    }
    return out
}

fn take_text(value, limit) {
    let text = str(value)
    if limit <= 0 { return "" }
    if text.len() <= limit { return text }
    let mut out = ""
    let mut i = 0
    while i < limit && i < text.len() {
        out = out + text[i]
        i = i + 1
    }
    return out
}

fn fit_text(value, width) {
    let clipped = take_text(single_line(value), width)
    let pad = width - clipped.len()
    if pad <= 0 { return clipped }
    return clipped + repeat_text(" ", pad)
}

fn color_code(name) {
    if name == "cyan" { return "36" }
    if name == "green" { return "32" }
    if name == "yellow" { return "33" }
    if name == "magenta" { return "35" }
    if name == "bright_white" { return "97" }
    if name == "bright_cyan" { return "96" }
    if name == "bright_green" { return "92" }
    if name == "bright_yellow" { return "93" }
    if name == "bright_magenta" { return "95" }
    return ""
}

fn style_open(row) {
    let color = color_code(arg(row, "fg", ""))
    let bold = arg(row, "bold", false)
    if bold && color != "" { return esc() + "[1;" + color + "m" }
    if bold { return esc() + "[1m" }
    if color != "" { return esc() + "[" + color + "m" }
    return ""
}

fn styled(row, text) {
    let open = style_open(row)
    if open == "" { return text }
    return open + text + ansi_reset()
}

fn border(label, width) {
    let inner = at_least(width, 4) - 2
    let title = " " + single_line(label) + " "
    if title.len() >= inner { return "+" + take_text(title, inner) + "+" }
    return "+" + title + repeat_text("-", inner - title.len()) + "+"
}

fn blank_line(width) {
    return "|" + repeat_text(" ", at_least(width, 2) - 2) + "|"
}

fn frame_line(text, width) {
    let inner = at_least(width, 2) - 2
    return "|" + fit_text(text, inner) + "|"
}

fn item_parts(row) {
    let mut prefix = "[" + arg(row, "kind", "item") + "]"
    let name = arg(row, "name", "")
    if name != "" { prefix = prefix + " " + name }
    let body = arg(row, "text", "")
    let lines = []
    if body == "" {
        lines.push(prefix)
        return lines
    }
    let parts = clean_text(body).split("\n")
    let mut i = 0
    while i < parts.len() {
        if i == 0 { lines.push(prefix + ": " + parts[i]) } else { lines.push("  " + parts[i]) }
        i = i + 1
    }
    return lines
}

fn slice_text(value, start, limit) {
    let text = str(value)
    if limit <= 0 { return "" }
    let mut out = ""
    let mut i = start
    let end = start + limit
    while i < end && i < text.len() {
        out = out + text[i]
        i = i + 1
    }
    return out
}

fn pad_text(value, width) {
    let text = str(value)
    let pad = width - text.len()
    if pad <= 0 { return text }
    return text + repeat_text(" ", pad)
}

fn wrapped_item_lines(row, width) {
    let inner = at_least(width, 2) - 2
    let lines = []
    for text in item_parts(row) {
        if text == "" {
            lines.push("|" + styled(row, repeat_text(" ", inner)) + "|")
        } else {
            let mut i = 0
            while i < text.len() {
                let part = slice_text(text, i, inner)
                lines.push("|" + styled(row, pad_text(part, inner)) + "|")
                i = i + inner
            }
        }
    }
    return lines
}

fn render_items(items, width, rows) {
    let lines = []
    for row in items {
        for line in wrapped_item_lines(row, width) { lines.push(line) }
    }
    let mut out = ""
    let mut start = 0
    if lines.len() > rows { start = lines.len() - rows }
    let mut i = 0
    while i < rows {
        let idx = start + i
        if idx < lines.len() { out = out + lines[idx] + "\n" } else { out = out + blank_line(width) + "\n" }
        i = i + 1
    }
    return out
}
fn render_view(view) {
    let width = at_least(arg(view, "width", 80), 20)
    let height = at_least(arg(view, "height", 10), 4)
    let body_rows = height - 3
    return border(arg(view, "title", "tetherscript"), width) + "\n" +
        render_items(arg(view, "items", []), width, body_rows) +
        border(arg(view, "status", ""), width) + "\n"
}

fn show(log, status) {
    let view = map()
    view.title = "tetherscript stdio agent"
    view.width = 80
    view.height = 10
    view.status = status
    view.items = log
    stdio_write_err(render_view(view))
}

fn present(log, status) {
    let size = terminal_size()
    let view = map()
    view.title = "tetherscript agent tui"
    view.width = size.cols
    view.height = size.rows
    view.status = status
    view.items = log
    print(ansi_clear_home() + render_view(view))
}

fn prop(desc) {
    let p = map()
    p.type = "string"
    p.description = desc
    return p
}

fn mcp_tool(name, desc, props, required) {
    let schema = map()
    schema.type = "object"
    schema.properties = props
    schema.required = required
    let out = map()
    out.name = name
    out.description = desc
    out.inputSchema = schema
    return out
}

fn model_tool(name, desc, props, required) {
    let params = map()
    params.type = "object"
    params.properties = props
    params.required = required
    let f = map()
    f.name = name
    f.description = desc
    f.parameters = params
    let t = map()
    t.type = "function"
    t.function = f
    return t
}

fn tool_defs(kind) {
    let defs = []
    defs.push(tool_for(kind, "cwd", "Return the current working directory.", map(), []))
    let mut p = map(); p.path = prop("Directory path.")
    defs.push(tool_for(kind, "ls", "List files in a directory.", p, ["path"]))
    p = map(); p.path = prop("File path.")
    defs.push(tool_for(kind, "read", "Read a UTF-8 file.", p, ["path"]))
    p = map(); p.path = prop("File or directory path.")
    defs.push(tool_for(kind, "exists", "Return whether a file or directory exists.", p, ["path"]))
    p = map(); p.path = prop("File or directory path.")
    defs.push(tool_for(kind, "stat", "Return file or directory metadata as JSON.", p, ["path"]))
    p = map(); p.path = prop("Directory path to create, including parents.")
    defs.push(tool_for(kind, "mkdir", "Create a directory and missing parents.", p, ["path"]))
    p = map(); p.path = prop("File path."); p.body = prop("UTF-8 file body to write.")
    defs.push(tool_for(kind, "write", "Write a UTF-8 file.", p, ["path", "body"]))
    p = map(); p.path = prop("File path."); p.body = prop("UTF-8 text to append.")
    defs.push(tool_for(kind, "append", "Append UTF-8 text to a file, creating it if needed.", p, ["path", "body"]))
    p = map(); p.path = prop("File path."); p.old = prop("Exact text to replace."); p.new = prop("Replacement text.")
    defs.push(tool_for(kind, "replace", "Replace exact text in a UTF-8 file.", p, ["path", "old", "new"]))
    p = map(); p.path = prop("File or directory path to remove.")
    defs.push(tool_for(kind, "remove", "Remove a file or directory tree.", p, ["path"]))
    p = map(); p.from = prop("Source path."); p.to = prop("Destination path.")
    defs.push(tool_for(kind, "copy", "Copy a file.", p, ["from", "to"]))
    p = map(); p.from = prop("Source path."); p.to = prop("Destination path.")
    defs.push(tool_for(kind, "rename", "Rename or move a file or directory.", p, ["from", "to"]))
    p = map(); p.command = prop("Shell command to run.")
    defs.push(tool_for(kind, "run", "Run a shell command using the platform default shell.", p, ["command"]))
    p = map(); p.command = prop("PowerShell command to run.")
    defs.push(tool_for(kind, "powershell", "Run a command with PowerShell.", p, ["command"]))
    p = map(); p.command = prop("Bash command to run.")
    defs.push(tool_for(kind, "bash", "Run a command with bash.", p, ["command"]))
    return defs
}

fn tool_for(kind, name, desc, props, required) {
    if kind == "mcp" { return mcp_tool(name, desc, props, required) }
    return model_tool(name, desc, props, required)
}

fn env_text(name) {
    let value = env_get(name).unwrap_or(nil)
    if value == nil { return "" }
    return value
}

fn default_model() {
    let mut model = env_text("TETHERSCRIPT_AGENT_MODEL")
    if model == "" { model = env_text("CODETETHER_DEFAULT_MODEL") }
    if model == "" { model = "zai/glm-5" }
    let info = provider.describe().unwrap()
    if info.endpoint.contains("openrouter.ai") { return openrouter_model(model) }
    if model.starts_with("openai/") { return model.replace("openai/", "") }
    if model.starts_with("openai-codex/") { return model.replace("openai-codex/", "") }
    if model.starts_with("openrouter/") { return model.replace("openrouter/", "") }
    if model.starts_with("cerebras/") { return model.replace("cerebras/", "") }
    if model.starts_with("zai/") { return model.replace("zai/", "") }
    if model.starts_with("zhipuai/") { return model.replace("zhipuai/", "") }
    return model
}

fn openrouter_model(model) {
    if model.starts_with("openrouter/") { return model.replace("openrouter/", "") }
    if model.starts_with("zai/") { return model.replace("zai/", "z-ai/") }
    return model
}

fn provider_ready() {
    return global_defined("provider")
}

fn provider_missing() {
    return "provider capability missing; configure provider secrets or grant a provider"
}

fn arg(args, key, fallback) {
    if type_of(args) == "map" && args.contains(key) { return args[key] }
    return fallback
}

fn shell(command) {
    if process_platform() == "windows" {
        return process_run("powershell", ["-NoProfile", "-Command", command], nil, 30000)
    }
    return process_run("sh", ["-lc", command], nil, 30000)
}

fn powershell(command) {
    return process_run("powershell", ["-NoProfile", "-Command", command], nil, 30000)
}

fn bash(command) {
    return process_run("bash", ["-lc", command], nil, 30000)
}

fn run_tool(name, args) {
    if name == "cwd" { return cwd().unwrap_or("cwd failed") }
    if name == "ls" { return json_encode(fs_list(arg(args, "path", ".")).unwrap_or([])) }
    if name == "read" { return fs_read(arg(args, "path", "")).unwrap_or("read failed") }
    if name == "exists" { return json_encode(fs_exists(arg(args, "path", "")).unwrap_or(false)) }
    if name == "stat" { return json_encode(fs_stat(arg(args, "path", "")).unwrap_or(map())) }
    if name == "mkdir" {
        let path = arg(args, "path", "")
        let r = fs_mkdir(path)
        if r.is_err() { return "mkdir failed: " + r.err() }
        return "created " + path
    }
    if name == "write" {
        let path = arg(args, "path", "")
        let r = fs_write(path, arg(args, "body", ""))
        if r.is_err() { return "write failed: " + r.err() }
        return "wrote " + path
    }
    if name == "append" {
        let path = arg(args, "path", "")
        let mut body = ""
        if fs_exists(path).unwrap_or(false) {
            let read = fs_read(path)
            if read.is_err() { return "append failed: " + read.err() }
            body = read.unwrap()
        }
        let r = fs_write(path, body + arg(args, "body", ""))
        if r.is_err() { return "append failed: " + r.err() }
        return "appended " + path
    }
    if name == "replace" {
        let path = arg(args, "path", "")
        let old = arg(args, "old", "")
        if old == "" { return "replace failed: old text is empty" }
        let read = fs_read(path)
        if read.is_err() { return "replace failed: " + read.err() }
        let body = read.unwrap()
        if !body.contains(old) { return "replace failed: old text not found" }
        let r = fs_write(path, body.replace(old, arg(args, "new", "")))
        if r.is_err() { return "replace failed: " + r.err() }
        return "replaced text in " + path
    }
    if name == "remove" { return json_encode(fs_remove(arg(args, "path", "")).unwrap_or(false)) }
    if name == "copy" {
        let r = fs_copy(arg(args, "from", ""), arg(args, "to", ""))
        if r.is_err() { return "copy failed: " + r.err() }
        return "copied " + str(r.unwrap()) + " bytes"
    }
    if name == "rename" {
        let r = fs_rename(arg(args, "from", ""), arg(args, "to", ""))
        if r.is_err() { return "rename failed: " + r.err() }
        return "renamed"
    }
    if name == "run" { return json_encode(shell(arg(args, "command", "")).unwrap_or(map())) }
    if name == "powershell" { return json_encode(powershell(arg(args, "command", "")).unwrap_or(map())) }
    if name == "bash" { return json_encode(bash(arg(args, "command", "")).unwrap_or(map())) }
    return "unknown tool: " + name
}

fn tool_failed(output) {
    if output.starts_with("unknown tool:") { return true }
    if output.starts_with("cwd failed") { return true }
    if output.starts_with("read failed") { return true }
    if output.starts_with("mkdir failed:") { return true }
    if output.starts_with("append failed:") { return true }
    if output.starts_with("write failed:") { return true }
    if output.starts_with("replace failed:") { return true }
    if output.starts_with("copy failed:") { return true }
    if output.starts_with("rename failed:") { return true }
    return false
}

fn text(value) {
    let part = map()
    part.type = "text"
    part.text = value
    return part
}

fn write_result(id, body, is_error) {
    let result = map()
    result.content = [text(body)]
    result.isError = is_error
    stdio_write(jsonrpc_response(id, result))
}

fn rpc_args(params) {
    if type_of(params) == "map" && params.contains("arguments") { return params.arguments }
    return map()
}

fn tools_call(log, id, params) {
    if type_of(params) != "map" || !params.contains("name") {
        return write_result(id, "tools/call: missing name", true)
    }
    let output = run_tool(params.name, rpc_args(params))
    log.push(item("tool", params.name, output))
    write_result(id, output, tool_failed(output))
}

fn tools_list(id) {
    let result = map()
    result.tools = tool_defs("mcp")
    stdio_write(jsonrpc_response(id, result))
}

fn initialize(id) {
    let result = map()
    result.protocolVersion = "2024-11-05"
    result.capabilities = map()
    result.capabilities.tools = map()
    result.serverInfo = map()
    result.serverInfo.name = "tetherscript-agent"
    result.serverInfo.version = "0.1.0"
    stdio_write(jsonrpc_response(id, result))
}

fn base_messages() {
    let messages = []
    let sys = map()
    sys.role = "system"
    sys.content = "You are a concise coding agent running in a local project workspace. For requests about the current project, repository, files, code, edits, diagnostics, or shell commands, use cwd, ls, read, write, and run tools to inspect and act locally. Do not ask the user to upload or paste files that the tools can read. Ask for content only when it is outside the accessible workspace or genuinely missing. Keep answers concise and report tool-backed changes clearly."
    messages.push(sys)
    return messages
}

fn new_session() {
    let session = map()
    session.messages = base_messages()
    return session
}

fn script_path() {
    let args = process_args()
    let mut i = args.len() - 1
    while i >= 0 {
        if args[i].ends_with(".tether") { return args[i] }
        i = i - 1
    }
    return "examples/agent_tui.tether"
}

fn file_version(path) {
    return fs_read(path).unwrap_or("")
}

fn reload_state() {
    let state = map()
    state.path = script_path()
    state.version = file_version(state.path)
    state.reloading = false
    return state
}

fn session_path() {
    return ".tetherscript/agent_tui_session.jsonl"
}

fn sessions_dir() {
    return ".tetherscript/sessions"
}

fn session_file(name) {
    return sessions_dir() + "/" + name.trim() + ".jsonl"
}

fn session_row(value) {
    return json_encode(value) + "\n"
}

fn session_body(session) {
    let mut body = ""
    for message in session.messages { body = body + session_row(message) }
    return body
}

fn load_session_at(path) {
    let raw = fs_read(path)
    if raw.is_err() { return nil }
    let session = map()
    session.messages = []
    for line in raw.unwrap().split("\n") {
        let trimmed = line.trim()
        if trimmed != "" { session.messages.push(json_parse(trimmed)) }
    }
    return session
}

fn load_session() {
    return load_session_at(session_path())
}

fn initial_session(saved) {
    if saved != nil && saved.contains("messages") && saved.messages.len() > 0 { return saved }
    return new_session()
}

fn initial_log(saved) {
    if saved != nil && saved.contains("messages") && saved.messages.len() > 0 {
        let log = [item("system", "ready", "restored session from jsonl; /save <name>, /load <name>, /sessions, /clear")]
        for message in saved.messages { append_log_message(log, message) }
        return log
    }
    return [item("system", "ready", "type a prompt; tools run automatically; /save <name>, /load <name>, /sessions")]
}

fn append_log_message(log, message) {
    if type_of(message) != "map" || !message.contains("role") { return nil }
    let content = arg(message, "content", "")
    if message.role == "system" { return nil }
    if message.role == "user" { log.push(item("user", "you", content)); return nil }
    if message.role == "assistant" && content != "" { log.push(item("agent", "provider", content)); return nil }
    if message.role == "tool" { log.push(item("tool", arg(message, "tool_call_id", "saved"), content)); return nil }
    return nil
}

fn clear_session() {
    fs_remove(session_path())
    return new_session()
}
fn save_session(session) {
    fs_mkdir(".tetherscript")
    fs_write(session_path(), session_body(session))
}

fn save_named_session(session, name) {
    let clean = name.trim()
    if clean == "" { return "usage: /save <name>" }
    fs_mkdir(sessions_dir())
    let r = fs_write(session_file(clean), session_body(session))
    if r.is_err() { return "save failed: " + r.err() }
    return "saved session " + clean
}

fn load_named_session(name) {
    let clean = name.trim()
    if clean == "" { return nil }
    return load_session_at(session_file(clean))
}

fn session_names() {
    let list = fs_list(sessions_dir()).unwrap_or([])
    let names = []
    for path in list {
        let name = str(path)
        if name.ends_with(".jsonl") { names.push(name.replace(".jsonl", "")) }
    }
    return names
}

fn check_output(report) {
    let stderr = arg(report, "stderr", "").trim()
    if stderr != "" { return stderr }
    let stdout = arg(report, "stdout", "").trim()
    if stdout != "" { return stdout }
    if arg(report, "timed_out", false) { return "check timed out" }
    return "check exited with code " + str(arg(report, "code", "unknown"))
}

fn self_check(path) {
    let args = process_args()
    if args.len() == 0 { return "process args did not include tetherscript binary" }
    let run = process_run(args[0], ["check", path], nil, 30000)
    if run.is_err() { return run.err() }
    let report = run.unwrap()
    if arg(report, "success", false) { return "" }
    return check_output(report)
}

fn reject_reload(log, state, reason) {
    let restore = fs_write(state.path, state.version)
    let mut text = "candidate rejected: " + single_line(reason)
    if restore.is_err() { text = text + "; restore failed: " + restore.err() }
    if restore.is_ok() { text = text + "; restored previous source" }
    log.push(item("system", "self-check", text))
}

fn reload_allowed(log, state) {
    let reason = self_check(state.path)
    if reason == "" {
        log.push(item("system", "self-check", "passed"))
        return true
    }
    reject_reload(log, state, reason)
    return false
}

fn reload_needed(state) {
    let current = file_version(state.path)
    if current == "" { return false }
    return current != state.version
}

fn reload_start(log, session, state) {
    log.push(item("system", "reload", "source changed; restarting"))
    state.reloading = true
    save_session(session)
    fs_mkdir(".tetherscript")
    fs_write(".tetherscript/reload", state.path)
}

fn reload_now(log, session, state) {
    if !reload_allowed(log, state) { return true }
    reload_start(log, session, state)
    present(log, "reloading")
    return false
}

fn reload_now_rpc(log, session, state) {
    if !reload_allowed(log, state) { return true }
    reload_start(log, session, state)
    show(log, "reloading")
    return false
}

fn parse_args(raw) {
    if type_of(raw) == "map" { return raw }
    if type_of(raw) != "str" || raw == "" { return map() }
    return json_parse(raw)
}

fn valid_tool(name) {
    if name == "cwd" { return true }
    if name == "ls" { return true }
    if name == "read" { return true }
    if name == "exists" { return true }
    if name == "stat" { return true }
    if name == "mkdir" { return true }
    if name == "write" { return true }
    if name == "append" { return true }
    if name == "replace" { return true }
    if name == "remove" { return true }
    if name == "copy" { return true }
    if name == "rename" { return true }
    if name == "run" { return true }
    if name == "powershell" { return true }
    if name == "bash" { return true }
    return false
}

fn call_name(call) {
    if call.contains("function") { return call.function.name }
    return call.name
}

fn call_args(call) {
    if call.contains("function") { return parse_args(call.function.arguments) }
    if call.contains("arguments") { return parse_args(call.arguments) }
    return map()
}

fn append_tool(log, messages, call) {
    let name = call_name(call)
    let output = run_tool(name, call_args(call))
    log.push(item("tool", name, output))
    let msg = map()
    msg.role = "tool"
    msg.tool_call_id = call.id
    msg.content = output
    messages.push(msg)
}

fn router_tools() {
    let defs = tool_defs("model")
    defs.push(model_tool("none", "No tool is needed.", map(), []))
    return defs
}

fn router_messages(messages, prompt, draft) {
    let out = []
    let sys = map()
    sys.role = "system"
    sys.content = "You are a tool-call router. Return exactly one tool call. Use none when no tool is needed, when the assistant draft already answers, or when the needed tool result is already in the conversation. Do not answer the user."
    out.push(sys)
    let user = map()
    user.role = "user"
    user.content = "Conversation JSON:\n" + json_encode(messages) + "\nLatest user prompt:\n" + prompt + "\nAssistant draft:\n" + draft
    out.push(user)
    return out
}

fn router_call(log, messages, state, draft) {
    let opts = map()
    opts.model = default_model()
    opts.tools = router_tools()
    opts.tool_choice = "required"
    opts.parallel_tool_calls = false
    opts.temperature = 0
    let result = provider.chat_json(router_messages(messages, state.prompt, draft), opts)
    if result.is_err() { return nil }
    let msg = result.unwrap().choices[0].message
    if !msg.contains("tool_calls") || msg.tool_calls.len() == 0 { return nil }
    let call = msg.tool_calls[0]
    let name = call_name(call)
    if name == "none" { return nil }
    if !valid_tool(name) {
        log.push(item("system", "router", "ignored unknown tool: " + name))
        return nil
    }
    return call
}

fn router_enabled() {
    return env_text("TETHERSCRIPT_AGENT_ROUTER") == "1"
}

fn normalize_call(call, messages) {
    if !call.contains("id") { call.id = "router-" + str(len(messages)) }
    if !call.contains("type") { call.type = "function" }
    if !call.contains("function") {
        let f = map()
        f.name = call.name
        f.arguments = json_encode(call_args(call))
        call.function = f
    }
    if !call.function.contains("arguments") { call.function.arguments = json_encode(map()) }
    return call
}

fn append_tool_call(messages, call) {
    let msg = map()
    msg.role = "assistant"
    msg.content = ""
    msg.tool_calls = [call]
    messages.push(msg)
}

fn agent_step(log, messages, state) {
    let opts = map()
    opts.model = default_model()
    opts.tools = tool_defs("model")
    opts.tool_choice = "auto"
    opts.parallel_tool_calls = true
    let result = provider.chat_json(messages, opts)
    if result.is_err() { state.answer = result.err(); return false }
    let msg = result.unwrap().choices[0].message
    if msg.contains("tool_calls") {
        messages.push(msg)
        for call in msg.tool_calls { append_tool(log, messages, call) }
        return true
    }
    state.answer = arg(msg, "content", "")
    if router_enabled() {
        let routed = router_call(log, messages, state, state.answer)
        if routed != nil {
            let call = normalize_call(routed, messages)
            append_tool_call(messages, call)
            append_tool(log, messages, call)
            return true
        }
    }
    messages.push(msg)
    if state.answer == "" {
        state.answer = "provider returned no content and no tool call"
    }
    return false
}

fn agent_turn(log, session, prompt) {
    let messages = session.messages
    let user = map()
    user.role = "user"
    user.content = prompt
    messages.push(user)
    let state = map()
    state.answer = ""
    state.prompt = prompt
    if !provider_ready() { return provider_missing() }
    while true {
        if !agent_step(log, messages, state) { return state.answer }
    }
}

fn prompt(params) {
    if type_of(params) != "map" { return "" }
    if params.contains("prompt") { return params.prompt }
    if params.contains("message") { return params.message }
    if params.contains("text") { return params.text }
    return ""
}

fn agent_message(log, session, id, params) {
    let question = prompt(params)
    log.push(item("user", "jsonrpc", question))
    let answer = agent_turn(log, session, question)
    log.push(item("agent", "provider", answer))
    write_result(id, answer, answer == provider_missing())
}

fn handle(log, session, reload, msg) {
    if !msg.contains("method") { return true }
    log.push(item("rpc", "in", msg.method))
    if msg.method == "initialize" { initialize(msg.id); return true }
    if msg.method == "tools/list" { tools_list(msg.id); return true }
    if msg.method == "tools/call" { tools_call(log, msg.id, msg.params) }
    if msg.method == "agent/message" { agent_message(log, session, msg.id, msg.params) }
    if msg.method != "tools/call" && msg.method != "agent/message" && msg.contains("id") {
        stdio_write(jsonrpc_error(msg.id, -32601, "method not found", msg.method))
    }
    if reload_needed(reload) { return reload_now_rpc(log, session, reload) }
    return true
}

fn manual_tool(command) {
    let trimmed = command.trim()
    if trimmed == "cwd" { return run_tool("cwd", map()) }
    if trimmed.starts_with("ls ") {
        let args = map()
        args.path = trimmed.replace("ls ", "")
        return run_tool("ls", args)
    }
    if trimmed.starts_with("read ") {
        let args = map()
        args.path = trimmed.replace("read ", "")
        return run_tool("read", args)
    }
    if trimmed.starts_with("run ") {
        let args = map()
        args.command = trimmed.replace("run ", "")
        return run_tool("run", args)
    }
    if trimmed.starts_with("powershell ") {
        let args = map()
        args.command = trimmed.replace("powershell ", "")
        return run_tool("powershell", args)
    }
    if trimmed.starts_with("bash ") {
        let args = map()
        args.command = trimmed.replace("bash ", "")
        return run_tool("bash", args)
    }
    if trimmed.starts_with("replace ") {
        return run_tool("replace", parse_args(trimmed.replace("replace ", "")))
    }
    return "tools: cwd, ls <path>, read <path>, replace path/old/new JSON, run|powershell|bash <command>"
}

fn new_input() {
    let input = map()
    input.multiline = false
    input.lines = []
    return input
}

fn input_status(input) {
    if input.multiline { return "multiline" }
    return "waiting"
}

fn send_prompt(log, session, reload, prompt) {
    log.push(item("user", "you", prompt))
    save_session(session)
    present(log, "working")
    let answer = agent_turn(log, session, prompt)
    log.push(item("agent", "provider", answer))
    save_session(session)
    if reload_needed(reload) { return reload_now(log, session, reload) }
    return true
}

fn restore_log(log, session, label) {
    while log.len() > 0 { log.pop() }
    log.push(item("system", "session", label))
    for message in session.messages { append_log_message(log, message) }
}

fn session_command(log, session, line) {
    if line == "/sessions" {
        let names = session_names()
        if names.len() == 0 { log.push(item("system", "sessions", "no named sessions")) } else { log.push(item("system", "sessions", names.join(", "))) }
        return true
    }
    if line.starts_with("/save ") {
        let name = line.replace("/save ", "")
        save_session(session)
        log.push(item("system", "session", save_named_session(session, name)))
        return true
    }
    if line.starts_with("/load ") {
        let name = line.replace("/load ", "").trim()
        let loaded = load_named_session(name)
        if loaded == nil {
            log.push(item("system", "session", "load failed: " + name))
            return true
        }
        session.messages = loaded.messages
        save_session(session)
        restore_log(log, session, "loaded session " + name)
        return true
    }
    return false
}
fn multiline_start(log, input, line) {
    input.multiline = true
    input.lines = []
    if line.starts_with("/multi ") { input.lines.push(line.replace("/multi ", "")) }
    log.push(item("system", "input", "multiline started; /send submits, /cancel cancels"))
    return true
}

fn multiline_handle(log, session, reload, input, line) {
    if line == "/send" {
        input.multiline = false
        let prompt = input.lines.join("\n")
        input.lines = []
        if prompt.trim() == "" {
            log.push(item("system", "input", "empty multiline ignored"))
            return true
        }
        return send_prompt(log, session, reload, prompt)
    }
    if line == "/cancel" {
        input.multiline = false
        input.lines = []
        log.push(item("system", "input", "multiline canceled"))
        return true
    }
    input.lines.push(line)
    return true
}

fn interactive_handle(log, session, reload, input, line) {
    if input.multiline { return multiline_handle(log, session, reload, input, line) }
    if line == "" { return true }
    if line == "/quit" { save_session(session); return false }
    if line == "/clear" {
        let fresh = clear_session()
        session.messages = fresh.messages
        while log.len() > 0 { log.pop() }
        log.push(item("system", "session", "cleared; type a prompt; /quit exits"))
        return true
    }
    if session_command(log, session, line) { return true }
    if line == "/tools" {
        log.push(item("system", "tools", "cwd, ls <path>, read <path>, replace path/old/new JSON, run|powershell|bash <command>"))
        return true
    }
    if line == "/multi" || line.starts_with("/multi ") {
        return multiline_start(log, input, line)
    }
    if line.starts_with("/tool ") {
        let command = line.replace("/tool ", "")
        log.push(item("tool", command, manual_tool(command)))
        return true
    }
    return send_prompt(log, session, reload, line)
}

fn interactive_main() {
    let saved = load_session()
    let log = initial_log(saved)
    let session = initial_session(saved)
    let reload = reload_state()
    let input = new_input()
    let mut running = true
    print(ansi_enter())
    while running {
        present(log, input_status(input))
        let event = tui_read_event("> ")
        if event.is_err() {
            log.push(item("system", "input", event.err()))
            running = false
        } else {
            running = interactive_handle(log, session, reload, input, event.unwrap().text)
        }
    }
    if reload.reloading { present(log, "reloading") } else { present(log, "done") }
    print(ansi_leave())
}

fn rpc_main() {
    let saved = load_session()
    let log = initial_log(saved)
    let session = initial_session(saved)
    let reload = reload_state()
    let mut running = true
    while running {
        show(log, "waiting")
        let read = stdio_read()
        if read.is_err() {
            stdio_write(jsonrpc_error(nil, -32700, read.err()))
        } else {
            let msg = read.unwrap()
            if msg == nil { running = false } else { running = handle(log, session, reload, msg) }
        }
    }
    show(log, "done")
}

fn main() {
    if env_text("TETHERSCRIPT_AGENT_MODE") == "rpc" { return rpc_main() }
    if env_text("TETHERSCRIPT_AGENT_STDIO_RPC") == "1" { return rpc_main() }
    interactive_main()
}
