// tetherscript: authority agent
// tetherscript: hot-reload

// -----------------------------------------------------------------------------
//  File:        agent_tui.tether
//  Purpose:     Local terminal UI + MCP/JSON-RPC agent host for TetherScript.
//  Author:      CodeTether / TetherScript contributors
//  Notes:       This example is intentionally self-contained and public-facing.
//
//  Overview:
//      agent_tui.tether is a small, inspectable agent runtime. It renders a
//      terminal UI, talks to a provider-backed chat model, exposes local tools,
//      persists sessions, supports hot reload, and can resume work after reload
//      with a self-prompt.
//
//  Modes:
//      1. Interactive TUI mode      default
//      2. JSON-RPC/MCP stdio mode   TETHERSCRIPT_AGENT_MODE=rpc
//
//  Major features:
//      - Framed ANSI terminal UI with colored log rows
//      - Clean multiline rendering and width wrapping
//      - File-system, shell, PowerShell, Bash, browser, and JavaScript tools
//      - Provider/model tool-call loop
//      - Optional router pass for one more tool call after a draft answer
//      - Default and named JSONL session persistence
//      - Hot reload with self-check and automatic continuation prompt
//
//  Storage:
//      .tetherscript/agent_tui_session.jsonl       default session
//      .tetherscript/sessions/<name>.jsonl         named sessions
//      .tetherscript/agent_tui_self_prompt.txt     reload continuation prompt
//      .tetherscript/reload                        hot-reload handoff marker
//
//  Public sharing note:
//      This file favors clarity over cleverness. Sections are separated with
//      old-fashioned comment blocks so readers can understand the runtime as a
//      sequence of simple subsystems rather than a hidden framework.
// -----------------------------------------------------------------------------

// =============================================================================
//  TEXT NORMALIZATION AND LOG ROWS
// =============================================================================

fn agent_version() {
    return "0.5.1"
}

fn agent_name() {
    return "tetherscript-agent-tui"
}

fn agent_label() {
    return agent_name() + " v" + agent_version()
}
fn bump_version_text(part) {
    let current = agent_version()
    let pieces = current.split(".")
    if pieces.len() < 3 { return current }
    let major = parse_int(pieces[0]).unwrap_or(0)
    let minor = parse_int(pieces[1]).unwrap_or(0)
    let patch = parse_int(pieces[2]).unwrap_or(0)
    if part == "major" { return str(major + 1) + ".0.0" }
    if part == "minor" { return str(major) + "." + str(minor + 1) + ".0" }
    return str(major) + "." + str(minor) + "." + str(patch + 1)
}

fn bump_version(part) {
    let next = bump_version_text(part)
    let path = script_path()
    let read = fs_read(path)
    if read.is_err() { return "version bump failed: " + read.err() }
    let body = read.unwrap()
    let old = "return \"" + agent_version() + "\""
    let new = "return \"" + next + "\""
    if !body.contains(old) { return "version bump failed: version literal not found" }
    let checkpoint = save_checkpoint(path, body)
    let r = fs_write(path, body.replace(old, new))
    if r.is_err() { return "version bump failed: " + r.err() }
    return "version bumped " + agent_version() + " -> " + next + "\n" + checkpoint
}
// Normalize text for one-line UI labels and borders.
fn single_line(value) {
    let mut text = str(value)
    text = text.replace("\r\n", "\\n")
    text = text.replace("\n", "\\n")
    return text.replace("\r", "\\n")
}

// Preserve real newlines for log body rendering while normalizing CRLF/CR.
fn clean_text(value) {
    let mut text = str(value)
    text = text.replace("\r\n", "\n")
    text = text.replace("\r", "\n")
    return text
}

// Build a typed log row. The kind controls color and rendering in the TUI.
fn item(kind, name, text) {
    let row = map()
    row.kind = kind
    row.name = name
    row.text = clean_text(text)
    if kind == "system" { row.fg = "bright_cyan"; row.bold = true }
    if kind == "user" { row.fg = "bright_white" }
    if kind == "agent" { row.fg = "bright_green" }
    if kind == "tool" { row.fg = "bright_yellow" }
    if kind == "rpc" { row.fg = "bright_magenta" }
    return row
}

// =============================================================================
//  ANSI TERMINAL CONTROL
// =============================================================================

// ANSI helpers for alternate-screen TUI rendering.
fn esc() {
    return b"\x1b".decode_utf8()
}

fn ansi_clear_home() {
    return esc() + "[2J" + esc() + "[H"
}

fn ansi_enter() {
    return esc() + "[?1049h" + esc() + "[?25l" + ansi_clear_home()
}

fn ansi_leave() {
    return esc() + "[0m" + esc() + "[?25h" + esc() + "[?1049l"
}

fn ansi_reset() {
    return esc() + "[0m"
}

fn env_int(name, fallback) {
    let raw = env_get(name).unwrap_or(nil)
    if raw == nil { return fallback }
    let parsed = parse_int(raw)
    if parsed.is_err() { return fallback }
    let value = parsed.unwrap()
    if value <= 0 { return fallback }
    return value
}

// =============================================================================
//  TERMINAL SIZING AND SMALL LAYOUT HELPERS
// =============================================================================

// Terminal dimensions come from environment variables supplied by the host.
fn terminal_size() {
    let size = map()
    size.cols = env_int("COLUMNS", 80)
    size.rows = env_int("LINES", 24)
    return size
}

fn at_least(value, floor) {
    if value < floor { return floor }
    return value
}

// Small string/layout helpers used by the frame renderer.
fn repeat_text(text, count) {
    let mut out = ""
    let mut i = 0
    while i < count {
        out = out + text
        i = i + 1
    }
    return out
}

fn take_text(value, limit) {
    let text = str(value)
    if limit <= 0 { return "" }
    if text.len() <= limit { return text }
    let mut out = ""
    let mut i = 0
    while i < limit && i < text.len() {
        out = out + text[i]
        i = i + 1
    }
    return out
}

fn fit_text(value, width) {
    let clipped = take_text(single_line(value), width)
    let pad = width - clipped.len()
    if pad <= 0 { return clipped }
    return clipped + repeat_text(" ", pad)
}

// =============================================================================
//  COLORS AND STYLING
// =============================================================================

// Map friendly color names to ANSI foreground color codes.
fn color_code(name) {
    if name == "cyan" { return "36" }
    if name == "green" { return "32" }
    if name == "yellow" { return "33" }
    if name == "magenta" { return "35" }
    if name == "bright_white" { return "97" }
    if name == "bright_cyan" { return "96" }
    if name == "bright_green" { return "92" }
    if name == "bright_yellow" { return "93" }
    if name == "bright_magenta" { return "95" }
    return ""
}

fn style_open(row) {
    let color = color_code(arg(row, "fg", ""))
    let bold = arg(row, "bold", false)
    if bold && color != "" { return esc() + "[1;" + color + "m" }
    if bold { return esc() + "[1m" }
    if color != "" { return esc() + "[" + color + "m" }
    return ""
}

fn styled(row, text) {
    let open = style_open(row)
    if open == "" { return text }
    return open + text + ansi_reset()
}

// =============================================================================
//  TUI FRAME AND LOG RENDERER
// =============================================================================

fn tui_ascii() {
    return env_text("TETHERSCRIPT_AGENT_ASCII") == "1"
}

fn utf8(bytes) {
    return bytes.decode_utf8()
}

fn box_char(kind) {
    if tui_ascii() {
        if kind == "h" { return "-" }
        if kind == "v" { return "|" }
        if kind == "tl" { return "+" }
        if kind == "tr" { return "+" }
        if kind == "ml" { return "+" }
        if kind == "mr" { return "+" }
        if kind == "bl" { return "+" }
        if kind == "br" { return "+" }
    }
    if kind == "h" { return utf8(b"\xE2\x94\x80") }
    if kind == "v" { return utf8(b"\xE2\x94\x82") }
    if kind == "tl" { return utf8(b"\xE2\x95\xAD") }
    if kind == "tr" { return utf8(b"\xE2\x95\xAE") }
    if kind == "ml" { return utf8(b"\xE2\x94\x9C") }
    if kind == "mr" { return utf8(b"\xE2\x94\xA4") }
    if kind == "bl" { return utf8(b"\xE2\x95\xB0") }
    if kind == "br" { return utf8(b"\xE2\x95\xAF") }
    return "?"
}
fn border_with(left, right, label, width) {
    let inner = at_least(width, 4) - 2
    let title = " " + single_line(label) + " "
    if title.len() >= inner { return left + take_text(title, inner) + right }
    return left + title + repeat_text(box_char("h"), inner - title.len()) + right
}

fn top_border(label, width) {
    return border_with(box_char("tl"), box_char("tr"), label, width)
}

fn mid_border(label, width) {
    return border_with(box_char("ml"), box_char("mr"), label, width)
}

fn bottom_border(label, width) {
    return border_with(box_char("bl"), box_char("br"), label, width)
}
// Draw the boxed TUI frame.
fn border(label, width) {
    let inner = at_least(width, 4) - 2
    let title = " " + single_line(label) + " "
    if title.len() >= inner { return "+" + take_text(title, inner) + "+" }
    return "+" + title + repeat_text("-", inner - title.len()) + "+"
}

fn blank_line(width) {
    return box_char("v") + repeat_text(" ", at_least(width, 2) - 2) + box_char("v")
}

fn frame_line(text, width) {
    let inner = at_least(width, 2) - 2
    return box_char("v") + fit_text(text, inner) + box_char("v")
}

// Split a log row into display lines. Real newlines become clean TUI rows.
fn item_parts(row) {
    let mut prefix = "[" + arg(row, "kind", "item") + "]"
    let name = arg(row, "name", "")
    if name != "" { prefix = prefix + " " + name }
    let body = arg(row, "text", "")
    let lines = []
    if body == "" {
        lines.push(prefix)
        return lines
    }
    let parts = clean_text(body).split("\n")
    let indent = repeat_text(" ", prefix.len() + 2)
    let mut i = 0
    while i < parts.len() {
        if i == 0 { lines.push(prefix + ": " + parts[i]) } else { lines.push(indent + parts[i]) }
        i = i + 1
    }
    return lines
}

fn slice_text(value, start, limit) {
    let text = str(value)
    if limit <= 0 { return "" }
    let mut out = ""
    let mut i = start
    let end = start + limit
    while i < end && i < text.len() {
        out = out + text[i]
        i = i + 1
    }
    return out
}

fn pad_text(value, width) {
    let text = str(value)
    let pad = width - text.len()
    if pad <= 0 { return text }
    return text + repeat_text(" ", pad)
}

// Wrap long display lines to the current terminal width instead of clipping them.
fn wrapped_item_lines(row, width) {
    let inner = at_least(width, 2) - 2
    let lines = []
    for text in item_parts(row) {
        if text == "" {
            lines.push(box_char("v") + styled(row, repeat_text(" ", inner)) + box_char("v"))
        } else {
            let mut i = 0
            while i < text.len() {
                let part = slice_text(text, i, inner)
                lines.push(box_char("v") + styled(row, pad_text(part, inner)) + box_char("v"))
                i = i + inner
            }
        }
    }
    return lines
}

// Flatten wrapped log rows and keep the newest visible rows at the bottom.
fn separator_mode() {
    let mode = env_text("TETHERSCRIPT_AGENT_SEPARATOR_MODE")
    if mode == "off" { return "off" }
    if mode == "compact" { return "compact" }
    if env_text("TETHERSCRIPT_AGENT_NO_SEPARATORS") == "1" { return "off" }
    return "full"
}

fn separator_enabled() {
    return separator_mode() != "off"
}

fn separator_line(width) {
    return box_char("v") + repeat_text(box_char("h"), at_least(width, 2) - 2) + box_char("v")
}

fn render_items(items, width, rows, scroll) {
    let lines = []
    let mut first = true
    for row in items {
        if !first && separator_enabled() && separator_mode() == "full" { lines.push(separator_line(width)) }
        first = false
        for line in wrapped_item_lines(row, width) { lines.push(line) }
    }
    let mut out = ""
    let mut start = 0
    if lines.len() > rows { start = lines.len() - rows - scroll }
    if start < 0 { start = 0 }
    let mut i = 0
    while i < rows {
        let idx = start + i
        if idx < lines.len() { out = out + lines[idx] + "\n" } else { out = out + blank_line(width) + "\n" }
        i = i + 1
    }
    return out
}
fn status_label(view) {
    let status = arg(view, "status", "")
    let scroll = arg(view, "scroll", 0)
    if scroll > 0 { return status + " | scroll +" + str(scroll) + " (/bottom)" }
    return status
}

// Render a complete framed TUI view: title, scrollable body, status panel, and bottom edge.
fn render_view(view) {
    let width = at_least(arg(view, "width", 80), 20)
    let height = at_least(arg(view, "height", 10), 5)
    let body_rows = height - 4
    return top_border(arg(view, "title", "tetherscript"), width) + "\n" +
        render_items(arg(view, "items", []), width, body_rows, arg(view, "scroll", 0)) +
        mid_border(" status ", width) + "\n" +
        frame_line(status_label(view), width) + "\n" +
        bottom_border("", width) + "\n"
}

fn show(log, status) {
    let view = map()
    view.title = agent_label() + " stdio"
    view.width = 80
    view.height = 10
    view.status = status
    view.items = log
    stdio_write_err(render_view(view))
}

fn present_at(log, status, scroll) {
    let size = terminal_size()
    let view = map()
    view.title = agent_label()
    view.width = size.cols
    view.height = size.rows
    view.status = status
    view.items = log
    view.scroll = scroll
    print(ansi_clear_home() + render_view(view))
}

fn present(log, status) {
    present_at(log, status, 0)
}

// =============================================================================
//  TOOL SCHEMAS
// =============================================================================

// Tool-schema helpers. These produce either MCP or model-function tool definitions.
fn prop(desc) {
    let p = map()
    p.type = "string"
    p.description = desc
    return p
}

fn mcp_tool(name, desc, props, required) {
    let schema = map()
    schema.type = "object"
    schema.properties = props
    schema.required = required
    let out = map()
    out.name = name
    out.description = desc
    out.inputSchema = schema
    return out
}

fn model_tool(name, desc, props, required) {
    let params = map()
    params.type = "object"
    params.properties = props
    params.required = required
    let f = map()
    f.name = name
    f.description = desc
    f.parameters = params
    let t = map()
    t.type = "function"
    t.function = f
    return t
}

// All tools exposed to the model/MCP clients. Keep this list in sync with run_tool().
fn tool_defs(kind) {
    let defs = []
    defs.push(tool_for(kind, "cwd", "Return the current working directory.", map(), []))
    let mut p = map(); p.path = prop("Directory path.")
    defs.push(tool_for(kind, "ls", "List files in a directory.", p, ["path"]))
    p = map(); p.path = prop("File path.")
    defs.push(tool_for(kind, "read", "Read a UTF-8 file.", p, ["path"]))
    p = map(); p.path = prop("File or directory path.")
    defs.push(tool_for(kind, "exists", "Return whether a file or directory exists.", p, ["path"]))
    p = map(); p.path = prop("File or directory path.")
    defs.push(tool_for(kind, "stat", "Return file or directory metadata as JSON.", p, ["path"]))
    p = map(); p.path = prop("Directory path to create, including parents.")
    defs.push(tool_for(kind, "mkdir", "Create a directory and missing parents.", p, ["path"]))
    p = map(); p.path = prop("File path."); p.body = prop("UTF-8 file body to write."); p.confirm = prop("Set to true when destructive confirmation is required.")
    defs.push(tool_for(kind, "write", "Write a UTF-8 file.", p, ["path", "body"]))
    p = map(); p.path = prop("File path."); p.body = prop("UTF-8 text to append.")
    defs.push(tool_for(kind, "append", "Append UTF-8 text to a file, creating it if needed.", p, ["path", "body"]))
    p = map(); p.path = prop("File path."); p.old = prop("Exact text to replace."); p.new = prop("Replacement text."); p.confirm = prop("Set to true when destructive confirmation is required.")
    defs.push(tool_for(kind, "replace", "Replace exact text in a UTF-8 file.", p, ["path", "old", "new"]))
    p = map(); p.path = prop("File or directory path to remove."); p.confirm = prop("Set to true when destructive confirmation is required.")
    defs.push(tool_for(kind, "remove", "Remove a file or directory tree.", p, ["path"]))
    p = map(); p.from = prop("Source path."); p.to = prop("Destination path.")
    defs.push(tool_for(kind, "copy", "Copy a file.", p, ["from", "to"]))
    p = map(); p.from = prop("Source path."); p.to = prop("Destination path.")
    defs.push(tool_for(kind, "rename", "Rename or move a file or directory.", p, ["from", "to"]))
    p = map(); p.command = prop("Shell command to run."); p.timeout_ms = prop("Optional timeout in milliseconds.")
    defs.push(tool_for(kind, "run", "Run a shell command using the platform default shell.", p, ["command"]))
    p = map(); p.command = prop("PowerShell command to run."); p.timeout_ms = prop("Optional timeout in milliseconds.")
    defs.push(tool_for(kind, "powershell", "Run a command with PowerShell.", p, ["command"]))
    p = map(); p.command = prop("Bash command to run."); p.timeout_ms = prop("Optional timeout in milliseconds.")
    defs.push(tool_for(kind, "bash", "Run a command with bash.", p, ["command"]))
    p = map(); p.html = prop("HTML document or fragment."); p.selector = prop("CSS selector.")
    defs.push(tool_for(kind, "browser_text", "Return textContent for a selector in HTML.", p, ["html", "selector"]))
    p = map(); p.html = prop("HTML document or fragment."); p.selector = prop("CSS selector.")
    defs.push(tool_for(kind, "browser_query", "Return the matched element HTML for a selector.", p, ["html", "selector"]))
    p = map(); p.html = prop("HTML document or fragment."); p.css = prop("CSS stylesheet."); p.width = prop("Render width in columns.")
    defs.push(tool_for(kind, "browser_render", "Render HTML and CSS to a text browser view.", p, ["html"]))
    p = map(); p.html = prop("HTML document containing scripts to execute.")
    defs.push(tool_for(kind, "browser_run_scripts", "Execute scripts embedded in HTML and return the result.", p, ["html"]))
    p = map(); p.script = prop("JavaScript source to evaluate.")
    defs.push(tool_for(kind, "js_eval", "Evaluate JavaScript and return the result.", p, ["script"]))
    return defs
}

fn tool_for(kind, name, desc, props, required) {
    if kind == "mcp" { return mcp_tool(name, desc, props, required) }
    return model_tool(name, desc, props, required)
}

fn env_text(name) {
    let value = env_get(name).unwrap_or(nil)
    if value == nil { return "" }
    return value
}

// =============================================================================
//  PROVIDER AND MODEL SELECTION
// =============================================================================

// Resolve the model name from environment variables and provider endpoint conventions.
fn default_model() {
    let mut model = env_text("TETHERSCRIPT_AGENT_MODEL")
    if model == "" { model = env_text("CODETETHER_DEFAULT_MODEL") }
    if model == "" { model = "zai/glm-5" }
    let info = provider.describe().unwrap()
    if info.endpoint.contains("openrouter.ai") { return openrouter_model(model) }
    if model.starts_with("openai/") { return model.replace("openai/", "") }
    if model.starts_with("openai-codex/") { return model.replace("openai-codex/", "") }
    if model.starts_with("openrouter/") { return model.replace("openrouter/", "") }
    if model.starts_with("cerebras/") { return model.replace("cerebras/", "") }
    if model.starts_with("zai/") { return model.replace("zai/", "") }
    if model.starts_with("zhipuai/") { return model.replace("zhipuai/", "") }
    return model
}

fn openrouter_model(model) {
    if model.starts_with("openrouter/") { return model.replace("openrouter/", "") }
    if model.starts_with("zai/") { return model.replace("zai/", "z-ai/") }
    return model
}

fn provider_ready() {
    return global_defined("provider")
}

fn provider_missing() {
    return "provider capability missing; configure provider secrets or grant a provider"
}

fn arg(args, key, fallback) {
    if type_of(args) == "map" && args.contains(key) { return args[key] }
    return fallback
}

// =============================================================================
//  TOOL EXECUTION BACKEND
// =============================================================================

// Shell adapters. run uses the platform default; explicit tools use PowerShell/Bash.
fn default_tool_timeout_ms() {
    return env_int("TETHERSCRIPT_AGENT_TOOL_TIMEOUT_MS", 30000)
}

fn tool_timeout_ms(args) {
    let raw = arg(args, "timeout_ms", "")
    if raw == "" { return default_tool_timeout_ms() }
    let parsed = parse_int(str(raw))
    if parsed.is_err() { return default_tool_timeout_ms() }
    let value = parsed.unwrap()
    if value <= 0 { return default_tool_timeout_ms() }
    return value
}

fn shell(command, timeout_ms) {
    if process_platform() == "windows" {
        return process_run("powershell", ["-NoProfile", "-Command", command], nil, timeout_ms)
    }
    return process_run("sh", ["-lc", command], nil, timeout_ms)
}

fn powershell(command, timeout_ms) {
    return process_run("powershell", ["-NoProfile", "-Command", command], nil, timeout_ms)
}

fn bash(command, timeout_ms) {
    return process_run("bash", ["-lc", command], nil, timeout_ms)
}

fn change_preview(path, before, after) {
    let before_text = str(before)
    let after_text = str(after)
    let delta = after_text.len() - before_text.len()
    let mut out = "change preview " + path + ": " + str(before_text.len()) + " -> " + str(after_text.len()) + " chars; delta=" + str(delta)
    let before_one = take_text(single_line(before_text), 160)
    let after_one = take_text(single_line(after_text), 160)
    if before_one != after_one {
        out = out + "\nbefore: " + before_one + "\nafter: " + after_one
    }
    return out
}
fn checkpoints_dir() {
    return ".tetherscript/checkpoints"
}

fn checkpoint_name(path) {
    let mut name = str(path)
    name = name.replace("\\", "_")
    name = name.replace("/", "_")
    name = name.replace(":", "_")
    if name == "" { name = "unnamed" }
    return name + ".bak"
}

fn checkpoint_path(path) {
    return checkpoints_dir() + "/" + checkpoint_name(path)
}

fn save_checkpoint(path, body) {
    fs_mkdir(checkpoints_dir())
    let target = checkpoint_path(path)
    let r = fs_write(target, body)
    if r.is_err() { return "checkpoint failed: " + r.err() }
    return "checkpoint saved: " + target
}

fn restore_checkpoint(path) {
    let source = checkpoint_path(path)
    let read = fs_read(source)
    if read.is_err() { return "restore failed: no checkpoint for " + path }
    let current = fs_read(path).unwrap_or("")
    let mut checkpoint = ""
    if current != "" { checkpoint = save_checkpoint(path, current) }
    let r = fs_write(path, read.unwrap())
    if r.is_err() { return "restore failed: " + r.err() }
    return "restored " + path + " from " + source + "\n" + checkpoint
}

fn checkpoint_names() {
    return json_encode(fs_list(checkpoints_dir()).unwrap_or([]))
}
fn destructive_confirm_enabled() {
    return env_text("TETHERSCRIPT_AGENT_CONFIRM_DESTRUCTIVE") == "1"
}

fn confirmed(args) {
    let value = arg(args, "confirm", false)
    if value == true { return true }
    if str(value) == "true" { return true }
    if str(value) == "1" { return true }
    return false
}

fn confirm_required(action, path) {
    return action + " blocked for " + path + ": set confirm=true or TETHERSCRIPT_AGENT_CONFIRM_DESTRUCTIVE=0"
}
// Execute a named tool. Tool outputs are returned as text for model/TUI consumption.
fn run_tool(name, args) {
    if name == "cwd" { return cwd().unwrap_or("cwd failed") }
    if name == "ls" { return json_encode(fs_list(arg(args, "path", ".")).unwrap_or([])) }
    if name == "read" { return fs_read(arg(args, "path", "")).unwrap_or("read failed") }
    if name == "exists" { return json_encode(fs_exists(arg(args, "path", "")).unwrap_or(false)) }
    if name == "stat" { return json_encode(fs_stat(arg(args, "path", "")).unwrap_or(map())) }
    if name == "mkdir" {
        let path = arg(args, "path", "")
        let r = fs_mkdir(path)
        if r.is_err() { return "mkdir failed: " + r.err() }
        return "created " + path
    }
    if name == "write" {
        let path = arg(args, "path", "")
        let existed = fs_exists(path).unwrap_or(false)
        if destructive_confirm_enabled() && existed && !confirmed(args) { return confirm_required("write overwrite", path) }
        let before = fs_read(path).unwrap_or("")
        let mut checkpoint = ""
        if existed { checkpoint = save_checkpoint(path, before) }
        let after = arg(args, "body", "")
        let r = fs_write(path, after)
        if r.is_err() { return "write failed: " + r.err() }
        return "wrote " + path + "\n" + checkpoint + "\n" + change_preview(path, before, after)
    }
    if name == "append" {
        let path = arg(args, "path", "")
        let mut body = ""
        if fs_exists(path).unwrap_or(false) {
            let read = fs_read(path)
            if read.is_err() { return "append failed: " + read.err() }
            body = read.unwrap()
        }
        let r = fs_write(path, body + arg(args, "body", ""))
        if r.is_err() { return "append failed: " + r.err() }
        return "appended " + path
    }
    if name == "replace" {
        let path = arg(args, "path", "")
        if destructive_confirm_enabled() && !confirmed(args) { return confirm_required("replace", path) }
        let old = arg(args, "old", "")
        if old == "" { return "replace failed: old text is empty" }
        let read = fs_read(path)
        if read.is_err() { return "replace failed: " + read.err() }
        let body = read.unwrap()
        if !body.contains(old) { return "replace failed: old text not found" }
        let after = body.replace(old, arg(args, "new", ""))
        let checkpoint = save_checkpoint(path, body)
        let r = fs_write(path, after)
        if r.is_err() { return "replace failed: " + r.err() }
        return "replaced text in " + path + "\n" + checkpoint + "\n" + change_preview(path, body, after)
    }
    if name == "remove" {
        let path = arg(args, "path", "")
        if destructive_confirm_enabled() && !confirmed(args) { return confirm_required("remove", path) }
        let before = fs_read(path).unwrap_or("")
        let mut checkpoint = ""
        if before != "" { checkpoint = save_checkpoint(path, before) }
        return checkpoint + "\nremoved=" + json_encode(fs_remove(path).unwrap_or(false))
    }
    if name == "copy" {
        let r = fs_copy(arg(args, "from", ""), arg(args, "to", ""))
        if r.is_err() { return "copy failed: " + r.err() }
        return "copied " + str(r.unwrap()) + " bytes"
    }
    if name == "rename" {
        let r = fs_rename(arg(args, "from", ""), arg(args, "to", ""))
        if r.is_err() { return "rename failed: " + r.err() }
        return "renamed"
    }
    if name == "run" { return json_encode(shell(arg(args, "command", ""), tool_timeout_ms(args)).unwrap_or(map())) }
    if name == "powershell" { return json_encode(powershell(arg(args, "command", ""), tool_timeout_ms(args)).unwrap_or(map())) }
    if name == "bash" { return json_encode(bash(arg(args, "command", ""), tool_timeout_ms(args)).unwrap_or(map())) }
    if name == "browser_text" { return browser_text_content(arg(args, "html", ""), arg(args, "selector", "body")) }
    if name == "browser_query" { return browser_query_selector(arg(args, "html", ""), arg(args, "selector", "body")) }
    if name == "browser_render" { return browser_render(arg(args, "html", ""), arg(args, "css", ""), parse_int(arg(args, "width", "80")).unwrap_or(80)) }
    if name == "browser_run_scripts" { return json_encode(browser_run_scripts(arg(args, "html", ""))) }
    if name == "js_eval" { return json_encode(js_eval(arg(args, "script", ""))) }
    return "unknown tool: " + name
}

fn tool_diagnostic(name, output) {
    let text = str(output)
    if tool_failed(text) { return "diagnostic: " + name + " failed; " + take_text(single_line(text), 240) }
    if text.contains("success") && text.contains("false") { return "diagnostic: " + name + " reported success=false; inspect stdout/stderr/code" }
    if text.contains("timed_out") && text.contains("true") { return "diagnostic: " + name + " timed out; retry with timeout_ms or narrow the command" }
    return ""
}

fn tool_log_text(name, output) {
    let summary = summarize_tool_output(output)
    let diag = tool_diagnostic(name, output)
    if diag == "" { return summary }
    return summary + "\n" + diag
}
fn summarize_tool_output(output) {
    let text = str(output)
    let limit = 2400
    if text.len() <= limit { return text }
    return take_text(text, limit) + "\n... tool output truncated in TUI log; full output kept in tool result (" + str(text.len()) + " chars)"
}
// Convert simple string outputs into JSON-RPC tool error status.
fn tool_failed(output) {
    if output.starts_with("unknown tool:") { return true }
    if output.starts_with("cwd failed") { return true }
    if output.starts_with("read failed") { return true }
    if output.starts_with("mkdir failed:") { return true }
    if output.starts_with("append failed:") { return true }
    if output.starts_with("write failed:") { return true }
    if output.starts_with("replace failed:") { return true }
    if output.starts_with("copy failed:") { return true }
    if output.starts_with("rename failed:") { return true }
    return false
}

fn text(value) {
    let part = map()
    part.type = "text"
    part.text = value
    return part
}

fn write_result(id, body, is_error) {
    let result = map()
    result.content = [text(body)]
    result.isError = is_error
    stdio_write(jsonrpc_response(id, result))
}

fn rpc_args(params) {
    if type_of(params) == "map" && params.contains("arguments") { return params.arguments }
    return map()
}

// =============================================================================
//  MCP / JSON-RPC SERVER HANDLERS
// =============================================================================

// MCP JSON-RPC handlers.
fn tools_call(log, id, params) {
    if type_of(params) != "map" || !params.contains("name") {
        return write_result(id, "tools/call: missing name", true)
    }
    let output = run_tool(params.name, rpc_args(params))
    log.push(item("tool", params.name, tool_log_text(params.name, output)))
    write_result(id, output, tool_failed(output))
}

fn tools_list(id) {
    let result = map()
    result.tools = tool_defs("mcp")
    stdio_write(jsonrpc_response(id, result))
}

fn initialize(id) {
    let result = map()
    result.protocolVersion = "2024-11-05"
    result.capabilities = map()
    result.capabilities.tools = map()
    result.serverInfo = map()
    result.serverInfo.name = agent_name()
    result.serverInfo.version = agent_version()
    stdio_write(jsonrpc_response(id, result))
}

// =============================================================================
//  CHAT SESSION AND SYSTEM PROMPT
// =============================================================================

// System prompt for the local coding agent.
fn base_messages() {
    let messages = []
    let sys = map()
    sys.role = "system"
    sys.content = "You are a concise coding agent running in a local project workspace. For requests about the current project, repository, files, code, edits, diagnostics, or shell commands, use cwd, ls, read, write, and run tools to inspect and act locally. Do not ask the user to upload or paste files that the tools can read. Ask for content only when it is outside the accessible workspace or genuinely missing. Keep answers concise and report tool-backed changes clearly."
    messages.push(sys)
    return messages
}

fn new_session() {
    let session = map()
    session.messages = base_messages()
    return session
}

// =============================================================================
//  HOT RELOAD AND SELF-PROMPT STATE
// =============================================================================

// Hot-reload state tracks the currently running .tether source file.
fn script_path() {
    let args = process_args()
    let mut i = args.len() - 1
    while i >= 0 {
        if args[i].ends_with(".tether") { return args[i] }
        i = i - 1
    }
    return "examples/agent_tui.tether"
}

fn file_version(path) {
    return fs_read(path).unwrap_or("")
}

fn reload_state() {
    let state = map()
    state.path = script_path()
    state.version = file_version(state.path)
    state.reloading = false
    return state
}

// Self-prompt persistence lets a hot-reloaded TUI continue the task that caused reload.
fn self_prompt_path() {
    return ".tetherscript/agent_tui_self_prompt.txt"
}

fn self_prompt_budget_path() {
    return ".tetherscript/agent_tui_self_prompt_budget.txt"
}

fn self_prompt_pause_path() {
    return ".tetherscript/agent_tui_self_prompt_paused"
}

fn self_prompt_paused() {
    return fs_exists(self_prompt_pause_path()).unwrap_or(false)
}

fn pause_self_prompt() {
    fs_mkdir(".tetherscript")
    fs_write(self_prompt_pause_path(), "paused")
    return "self-prompt continuation paused"
}

fn resume_self_prompt() {
    fs_remove(self_prompt_pause_path())
    return "self-prompt continuation resumed"
}
fn next_feature_path() {
    return ".tetherscript/agent_tui_next_feature.txt"
}

fn default_next_feature() {
    return "Commit TUI separator rendering controls."
}

fn read_next_feature() {
    let raw = fs_read(next_feature_path())
    if raw.is_err() { return default_next_feature() }
    let text = raw.unwrap().trim()
    if text == "" { return default_next_feature() }
    return text
}

fn write_next_feature(feature) {
    let text = feature.trim()
    if text == "" { return "usage: /next <feature>" }
    fs_mkdir(".tetherscript")
    fs_write(next_feature_path(), text)
    return "next feature recorded: " + text
}

fn self_prompt_continue_text() {
    return "Continue the ongoing TUI-agent improvement objective. There is more to do. Next feature to consider: " + read_next_feature() + "\n\nInspect the current file, choose the next highest-leverage small improvement, implement it safely, verify it, and report concise status. Before completing the turn, record the next feature to consider in the reload prompt/next-feature state and preserve the continuation indicator so the next reload keeps moving."
}

fn read_self_prompt_budget() {
    let raw = fs_read(self_prompt_budget_path())
    if raw.is_err() { return 0 }
    let parsed = parse_int(raw.unwrap().trim())
    if parsed.is_err() { return 0 }
    let value = parsed.unwrap()
    if value < 0 { return 0 }
    return value
}

fn write_self_prompt_budget(value) {
    fs_mkdir(".tetherscript")
    fs_write(self_prompt_budget_path(), str(value))
}

fn consume_self_prompt_budget() {
    let budget = read_self_prompt_budget()
    if budget <= 0 { return false }
    write_self_prompt_budget(budget - 1)
    return true
}

fn seed_self_prompt(goal, budget) {
    fs_mkdir(".tetherscript")
    fs_write(self_prompt_path(), goal)
    write_self_prompt_budget(budget)
    return "self-prompt queued with " + str(budget) + " continuation step(s); each step must choose and record the next feature before finishing"
}

fn stop_self_prompt() {
    write_self_prompt_budget(0)
    fs_remove(self_prompt_path())
    return "self-prompt continuation stopped"
}
fn set_self_prompt_budget_text(raw) {
    let parsed = parse_int(raw.trim())
    if parsed.is_err() { return "usage: /self-budget <number>" }
    let value = parsed.unwrap()
    if value < 0 { return "usage: /self-budget <number>" }
    write_self_prompt_budget(value)
    return "self-prompt budget set to " + str(value)
}
fn last_user_prompt(session) {
    let mut i = session.messages.len() - 1
    while i >= 0 {
        let message = session.messages[i]
        if type_of(message) == "map" && arg(message, "role", "") == "user" {
            return arg(message, "content", "")
        }
        i = i - 1
    }
    return ""
}

fn reload_prompt_context(prompt) {
    if prompt.starts_with("The TUI reloaded after source changes") { return "ongoing autonomous TUI-agent improvement loop" }
    if prompt.starts_with("Continue the ongoing TUI-agent improvement objective") { return "ongoing autonomous TUI-agent improvement loop" }
    return prompt
}

fn save_self_prompt(session) {
    let prompt = reload_prompt_context(last_user_prompt(session))
    if prompt == "" { return nil }
    fs_mkdir(".tetherscript")
    let body = "The TUI reloaded after source changes.\n\nCurrent objective: " + prompt + "\n\nNext feature to consider: " + read_next_feature() + "\n\nContinue from the reloaded state. Verify the change if useful, then report concise status. Before completing the turn, record the next feature to consider in the reload prompt/next-feature state. If more improvement remains, preserve the continuation indicator so the next reload keeps moving."
    fs_write(self_prompt_path(), body)
    return nil
}

fn load_self_prompt() {
    if self_prompt_paused() { return "" }
    let raw = fs_read(self_prompt_path())
    if raw.is_err() { return "" }
    fs_remove(self_prompt_path())
    let prompt = raw.unwrap()
    if consume_self_prompt_budget() {
        fs_write(self_prompt_path(), self_prompt_continue_text())
    }
    return prompt
}
// =============================================================================
//  SESSION PERSISTENCE
// =============================================================================

// Session persistence. Default and named sessions are JSONL conversation logs.
fn session_path() {
    return ".tetherscript/agent_tui_session.jsonl"
}

fn sessions_dir() {
    return ".tetherscript/sessions"
}

fn session_file(name) {
    return sessions_dir() + "/" + name.trim() + ".jsonl"
}

fn session_row(value) {
    return json_encode(value) + "\n"
}

fn session_body(session) {
    let mut body = ""
    for message in session.messages { body = body + session_row(message) }
    return body
}

fn load_session_at(path) {
    let raw = fs_read(path)
    if raw.is_err() { return nil }
    let session = map()
    session.messages = []
    for line in raw.unwrap().split("\n") {
        let trimmed = line.trim()
        if trimmed != "" { session.messages.push(json_parse(trimmed)) }
    }
    return session
}

fn load_session() {
    return load_session_at(session_path())
}

fn initial_session(saved) {
    if saved != nil && saved.contains("messages") && saved.messages.len() > 0 { return saved }
    return new_session()
}

// Rebuild the visible TUI log from persisted chat messages.
fn onboarding_text() {
    return "welcome to " + agent_label() + "; start with /palette, /examples, /checklist, or type a coding request. Use /self <goal> for autonomous continuation."
}

fn startup_checklist_text() {
    let provider = "missing"
    if provider_ready() { provider = "ready" }
    return "startup: provider=" + provider + "; session=" + session_path() + "; next=" + read_next_feature() + "; use /config, /provider, /health for details"
}

fn initial_log(saved) {
    if saved != nil && saved.contains("messages") && saved.messages.len() > 0 {
        let log = [item("system", "ready", "restored session from jsonl; /help for commands")]
        for message in saved.messages { append_log_message(log, message) }
        return log
    }
    return [item("system", "ready", onboarding_text()), item("system", "checklist", startup_checklist_text())]
}

fn append_log_message(log, message) {
    if type_of(message) != "map" || !message.contains("role") { return nil }
    let content = arg(message, "content", "")
    if message.role == "system" { return nil }
    if message.role == "user" { log.push(item("user", "you", content)); return nil }
    if message.role == "assistant" && content != "" { log.push(item("agent", "provider", content)); return nil }
    if message.role == "tool" { log.push(item("tool", arg(message, "tool_call_id", "saved"), content)); return nil }
    return nil
}

fn clear_session() {
    fs_remove(session_path())
    return new_session()
}
// Persist the current/default session after turns and on exit.
fn save_session(session) {
    fs_mkdir(".tetherscript")
    fs_write(session_path(), session_body(session))
}

fn save_named_session(session, name) {
    let clean = name.trim()
    if clean == "" { return "usage: /save <name>" }
    fs_mkdir(sessions_dir())
    let r = fs_write(session_file(clean), session_body(session))
    if r.is_err() { return "save failed: " + r.err() }
    return "saved session " + clean
}

fn load_named_session(name) {
    let clean = name.trim()
    if clean == "" { return nil }
    return load_session_at(session_file(clean))
}

fn session_names() {
    let list = fs_list(sessions_dir()).unwrap_or([])
    let names = []
    for path in list {
        let name = str(path)
        if name.ends_with(".jsonl") { names.push(name.replace(".jsonl", "")) }
    }
    return names
}
fn exports_dir() {
    return ".tetherscript/exports"
}

fn export_path(name) {
    return exports_dir() + "/" + name.trim() + ".md"
}

fn export_message(message) {
    if type_of(message) != "map" || !message.contains("role") { return "" }
    let role = arg(message, "role", "message")
    let content = arg(message, "content", "")
    if content == "" && message.contains("tool_calls") { content = json_encode(message.tool_calls) }
    return "## " + role + "\n\n" + content + "\n\n"
}

fn export_session(session, name) {
    let clean = name.trim()
    if clean == "" { clean = "agent_tui_transcript" }
    fs_mkdir(exports_dir())
    let mut body = "# " + agent_label() + " transcript\n\n"
    body = body + "Exported from " + session_path() + "\n\n"
    for message in session.messages { body = body + export_message(message) }
    let path = export_path(clean)
    let r = fs_write(path, body)
    if r.is_err() { return "export failed: " + r.err() }
    return "exported transcript to " + path
}

fn check_output(report) {
    let stderr = arg(report, "stderr", "").trim()
    if stderr != "" { return stderr }
    let stdout = arg(report, "stdout", "").trim()
    if stdout != "" { return stdout }
    if arg(report, "timed_out", false) { return "check timed out" }
    return "check exited with code " + str(arg(report, "code", "unknown"))
}

fn timeline_entry(index, message) {
    if type_of(message) != "map" || !message.contains("role") { return "" }
    let role = arg(message, "role", "message")
    let content = single_line(arg(message, "content", ""))
    if content == "" && message.contains("tool_calls") { content = "tool_calls=" + str(message.tool_calls.len()) }
    return str(index) + ". " + role + ": " + take_text(content, 96)
}

fn event_log_path() {
    return ".tetherscript/agent_tui_events.jsonl"
}

fn log_event(kind, name, text) {
    let event = map()
    event.kind = kind
    event.name = name
    event.text = single_line(text)
    event.version = agent_version()
    fs_mkdir(".tetherscript")
    fs_write(event_log_path(), fs_read(event_log_path()).unwrap_or("") + json_encode(event) + "\n")
    return nil
}

fn recent_events() {
    let raw = fs_read(event_log_path())
    if raw.is_err() { return "no events" }
    let lines = []
    for line in raw.unwrap().split("\n") {
        let trimmed = line.trim()
        if trimmed != "" { lines.push(trimmed) }
    }
    if lines.len() == 0 { return "no events" }
    let mut start = 0
    if lines.len() > 12 { start = lines.len() - 12 }
    let recent = []
    let mut i = start
    while i < lines.len() {
        recent.push(lines[i])
        i = i + 1
    }
    return recent.join("\n")
}
fn clear_events() {
    fs_remove(event_log_path())
    return "events cleared"
}

fn clear_bookmarks() {
    fs_remove(bookmarks_path())
    return "bookmarks cleared"
}
fn bookmarks_path() {
    return ".tetherscript/agent_tui_bookmarks.jsonl"
}

fn bookmark_row(label, index, text) {
    let row = map()
    row.label = label
    row.index = index
    row.text = text
    return json_encode(row) + "\n"
}

fn add_bookmark(session, label) {
    let clean = label.trim()
    if clean == "" { clean = "bookmark" }
    let index = session.messages.len() - 1
    if index < 0 { return "bookmark failed: no messages" }
    let message = session.messages[index]
    let text = take_text(single_line(arg(message, "content", "")), 180)
    fs_mkdir(".tetherscript")
    fs_write(bookmarks_path(), fs_read(bookmarks_path()).unwrap_or("") + bookmark_row(clean, index, text))
    return "bookmarked message " + str(index) + " as " + clean
}

fn list_bookmarks() {
    let raw = fs_read(bookmarks_path())
    if raw.is_err() { return "no bookmarks" }
    let lines = []
    for line in raw.unwrap().split("\n") {
        let trimmed = line.trim()
        if trimmed != "" {
            let row = json_parse(trimmed)
            lines.push(str(arg(row, "index", "?")) + " [" + arg(row, "label", "bookmark") + "] " + arg(row, "text", ""))
        }
    }
    if lines.len() == 0 { return "no bookmarks" }
    return lines.join("\n")
}
fn timeline_text(session) {
    let lines = []
    let mut user_count = 0
    let mut assistant_count = 0
    let mut tool_count = 0
    let mut i = 0
    for message in session.messages {
        let role = arg(message, "role", "")
        if role == "user" { user_count = user_count + 1 }
        if role == "assistant" { assistant_count = assistant_count + 1 }
        if role == "tool" { tool_count = tool_count + 1 }
        let entry = timeline_entry(i, message)
        if entry != "" { lines.push(entry) }
        i = i + 1
    }
    let mut start = 0
    if lines.len() > 12 { start = lines.len() - 12 }
    let recent = []
    let mut j = start
    while j < lines.len() {
        recent.push(lines[j])
        j = j + 1
    }
    return "timeline messages=" + str(session.messages.len()) + "; user=" + str(user_count) + "; assistant=" + str(assistant_count) + "; tool=" + str(tool_count) + "\n" + recent.join("\n")
}
// =============================================================================
//  SELF-CHECKED HOT RELOAD
// =============================================================================

// Before hot-reloading changed source, ask the TetherScript binary to check it.
fn self_check(path) {
    let args = process_args()
    if args.len() == 0 { return "process args did not include tetherscript binary" }
    let run = process_run(args[0], ["check", path], nil, 30000)
    if run.is_err() { return run.err() }
    let report = run.unwrap()
    if arg(report, "success", false) { return "" }
    return check_output(report)
}

fn reject_reload(log, state, reason) {
    let restore = fs_write(state.path, state.version)
    let mut text = "candidate rejected: " + single_line(reason)
    if restore.is_err() { text = text + "; restore failed: " + restore.err() }
    if restore.is_ok() { text = text + "; restored previous source" }
    log.push(item("system", "self-check", text))
}

fn reload_allowed(log, state) {
    let reason = self_check(state.path)
    if reason == "" {
        log.push(item("system", "self-check", "passed"))
        return true
    }
    reject_reload(log, state, reason)
    return false
}

fn reload_needed(state) {
    let current = file_version(state.path)
    if current == "" { return false }
    return current != state.version
}

fn reload_start(log, session, state) {
    log.push(item("system", "reload", "source changed; restarting"))
    log_event("system", "reload", "source changed; restarting")
    state.reloading = true
    save_self_prompt(session)
    save_session(session)
    fs_mkdir(".tetherscript")
    fs_write(".tetherscript/reload", state.path)
}

// Hot reload: save session, request restart, and let the outer host relaunch us.
fn reload_now(log, session, state) {
    if !reload_allowed(log, state) { return true }
    reload_start(log, session, state)
    present(log, "reloading")
    return false
}

fn reload_now_rpc(log, session, state) {
    if !reload_allowed(log, state) { return true }
    reload_start(log, session, state)
    show(log, "reloading")
    return false
}

fn parse_args(raw) {
    if type_of(raw) == "map" { return raw }
    if type_of(raw) != "str" || raw == "" { return map() }
    return json_parse(raw)
}

// =============================================================================
//  MODEL TOOL-CALL LOOP AND ROUTER
// =============================================================================

// Router allow-list. The router can only request tools declared here.
fn valid_tool(name) {
    if name == "cwd" { return true }
    if name == "ls" { return true }
    if name == "read" { return true }
    if name == "exists" { return true }
    if name == "stat" { return true }
    if name == "mkdir" { return true }
    if name == "write" { return true }
    if name == "append" { return true }
    if name == "replace" { return true }
    if name == "remove" { return true }
    if name == "copy" { return true }
    if name == "rename" { return true }
    if name == "run" { return true }
    if name == "powershell" { return true }
    if name == "bash" { return true }
    if name == "browser_text" { return true }
    if name == "browser_query" { return true }
    if name == "browser_render" { return true }
    if name == "browser_run_scripts" { return true }
    if name == "js_eval" { return true }
    return false
}

fn call_name(call) {
    if call.contains("function") { return call.function.name }
    return call.name
}

fn call_args(call) {
    if call.contains("function") { return parse_args(call.function.arguments) }
    if call.contains("arguments") { return parse_args(call.arguments) }
    return map()
}

// Execute a model tool call, log it, and append the tool result to chat history.
fn append_tool(log, messages, call) {
    let name = call_name(call)
    let output = run_tool(name, call_args(call))
    log.push(item("tool", name, tool_log_text(name, output)))
    let msg = map()
    msg.role = "tool"
    msg.tool_call_id = call.id
    msg.content = output
    messages.push(msg)
}

// Optional second-pass router: decides whether a draft answer needs one more tool call.
fn router_tools() {
    let defs = tool_defs("model")
    defs.push(model_tool("none", "No tool is needed.", map(), []))
    return defs
}

fn router_messages(messages, prompt, draft) {
    let out = []
    let sys = map()
    sys.role = "system"
    sys.content = "You are a tool-call router. Return exactly one tool call. Use none when no tool is needed, when the assistant draft already answers, or when the needed tool result is already in the conversation. Do not answer the user."
    out.push(sys)
    let user = map()
    user.role = "user"
    user.content = "Conversation JSON:\n" + json_encode(messages) + "\nLatest user prompt:\n" + prompt + "\nAssistant draft:\n" + draft
    out.push(user)
    return out
}

fn router_call(log, messages, state, draft) {
    let opts = map()
    opts.model = default_model()
    opts.tools = router_tools()
    opts.tool_choice = "required"
    opts.parallel_tool_calls = false
    opts.temperature = 0
    let result = provider.chat_json(router_messages(messages, state.prompt, draft), opts)
    if result.is_err() { return nil }
    let msg = result.unwrap().choices[0].message
    if !msg.contains("tool_calls") || msg.tool_calls.len() == 0 { return nil }
    let call = msg.tool_calls[0]
    let name = call_name(call)
    if name == "none" { return nil }
    if !valid_tool(name) {
        log.push(item("system", "router", "ignored unknown tool: " + name))
        return nil
    }
    return call
}

fn router_enabled() {
    return env_text("TETHERSCRIPT_AGENT_ROUTER") == "1"
}

fn normalize_call(call, messages) {
    if !call.contains("id") { call.id = "router-" + str(len(messages)) }
    if !call.contains("type") { call.type = "function" }
    if !call.contains("function") {
        let f = map()
        f.name = call.name
        f.arguments = json_encode(call_args(call))
        call.function = f
    }
    if !call.function.contains("arguments") { call.function.arguments = json_encode(map()) }
    return call
}

fn append_tool_call(messages, call) {
    let msg = map()
    msg.role = "assistant"
    msg.content = ""
    msg.tool_calls = [call]
    messages.push(msg)
}

// One provider round-trip. Handles tool calls until a final assistant answer appears.
fn agent_step(log, messages, state) {
    let opts = map()
    opts.model = default_model()
    opts.tools = tool_defs("model")
    opts.tool_choice = "auto"
    opts.parallel_tool_calls = true
    let result = provider.chat_json(messages, opts)
    if result.is_err() { state.answer = result.err(); return false }
    let msg = result.unwrap().choices[0].message
    if msg.contains("tool_calls") {
        messages.push(msg)
        for call in msg.tool_calls { append_tool(log, messages, call) }
        return true
    }
    state.answer = arg(msg, "content", "")
    if router_enabled() {
        let routed = router_call(log, messages, state, state.answer)
        if routed != nil {
            let call = normalize_call(routed, messages)
            append_tool_call(messages, call)
            append_tool(log, messages, call)
            return true
        }
    }
    messages.push(msg)
    if state.answer == "" {
        state.answer = "provider returned no content and no tool call"
    }
    return false
}

// Complete user turn: append prompt, run provider/tool loop, return final answer.
fn agent_turn(log, session, prompt) {
    let messages = session.messages
    let user = map()
    user.role = "user"
    user.content = prompt
    messages.push(user)
    let state = map()
    state.answer = ""
    state.prompt = prompt
    if !provider_ready() { return provider_missing() }
    while true {
        if !agent_step(log, messages, state) { return state.answer }
    }
}

fn prompt(params) {
    if type_of(params) != "map" { return "" }
    if params.contains("prompt") { return params.prompt }
    if params.contains("message") { return params.message }
    if params.contains("text") { return params.text }
    return ""
}

fn agent_message(log, session, id, params) {
    let question = prompt(params)
    log.push(item("user", "jsonrpc", question))
    let answer = agent_turn(log, session, question)
    log.push(item("agent", "provider", answer))
    write_result(id, answer, answer == provider_missing())
}

fn handle(log, session, reload, msg) {
    if !msg.contains("method") { return true }
    log.push(item("rpc", "in", msg.method))
    if msg.method == "initialize" { initialize(msg.id); return true }
    if msg.method == "tools/list" { tools_list(msg.id); return true }
    if msg.method == "tools/call" { tools_call(log, msg.id, msg.params) }
    if msg.method == "agent/message" { agent_message(log, session, msg.id, msg.params) }
    if msg.method != "tools/call" && msg.method != "agent/message" && msg.contains("id") {
        stdio_write(jsonrpc_error(msg.id, -32601, "method not found", msg.method))
    }
    if reload_needed(reload) { return reload_now_rpc(log, session, reload) }
    return true
}

// =============================================================================
//  INTERACTIVE TUI COMMANDS AND INPUT
// =============================================================================

// Manual TUI tool escape hatch: /tool ... executes without asking the model.
fn manual_tool(command) {
    let trimmed = command.trim()
    if trimmed == "cwd" { return run_tool("cwd", map()) }
    if trimmed.starts_with("ls ") {
        let args = map()
        args.path = trimmed.replace("ls ", "")
        return run_tool("ls", args)
    }
    if trimmed.starts_with("read ") {
        let args = map()
        args.path = trimmed.replace("read ", "")
        return run_tool("read", args)
    }
    if trimmed.starts_with("run ") {
        let args = map()
        args.command = trimmed.replace("run ", "")
        return run_tool("run", args)
    }
    if trimmed.starts_with("powershell ") {
        let args = map()
        args.command = trimmed.replace("powershell ", "")
        return run_tool("powershell", args)
    }
    if trimmed.starts_with("bash ") {
        let args = map()
        args.command = trimmed.replace("bash ", "")
        return run_tool("bash", args)
    }
    if trimmed.starts_with("js ") {
        let args = map()
        args.script = trimmed.replace("js ", "")
        return run_tool("js_eval", args)
    }
    if trimmed.starts_with("browser_text ") {
        return run_tool("browser_text", parse_args(trimmed.replace("browser_text ", "")))
    }
    if trimmed.starts_with("browser_query ") {
        return run_tool("browser_query", parse_args(trimmed.replace("browser_query ", "")))
    }
    if trimmed.starts_with("browser_render ") {
        return run_tool("browser_render", parse_args(trimmed.replace("browser_render ", "")))
    }
    if trimmed.starts_with("browser_run_scripts ") {
        let args = map()
        args.html = trimmed.replace("browser_run_scripts ", "")
        return run_tool("browser_run_scripts", args)
    }
    if trimmed.starts_with("replace ") {
        return run_tool("replace", parse_args(trimmed.replace("replace ", "")))
    }
    return "tools: cwd, ls <path>, read <path>, replace path/old/new JSON, run|powershell|bash <command> or JSON timeout_ms, js <script>, browser_text|browser_query|browser_render JSON"
}

// Input state supports single-line prompts and /multi multiline prompts.
fn new_input() {
    let input = map()
    input.multiline = false
    input.lines = []
    input.scroll = 0
    return input
}

fn input_status(input) {
    if input.multiline { return "multiline input: /send submits, /cancel cancels" }
    return "waiting for you"
}

fn status_with_hints(input) {
    return input_status(input) + " | /h help /s status /r map /u up /j down /b end /q quit"
}
// Send a prompt from the TUI, save session state, and trigger hot reload if needed.
fn send_prompt(log, session, reload, prompt) {
    log.push(item("user", "you", prompt))
    log_event("user", "prompt", prompt)
    save_session(session)
    present(log, "agent working")
    let answer = agent_turn(log, session, prompt)
    log.push(item("agent", "provider", answer))
    log_event("agent", "provider", answer)
    save_session(session)
    if reload_needed(reload) { return reload_now(log, session, reload) }
    return true
}

// Named-session helpers used by /save, /load, and /sessions.
fn restore_log(log, session, label) {
    while log.len() > 0 { log.pop() }
    log.push(item("system", "session", label))
    for message in session.messages { append_log_message(log, message) }
}

fn session_command(log, session, line) {
    if line == "/sessions" {
        let names = session_names()
        if names.len() == 0 { log.push(item("system", "sessions", "no named sessions")) } else { log.push(item("system", "sessions", names.join(", "))) }
        return true
    }
    if line.starts_with("/save ") {
        let name = line.replace("/save ", "")
        save_session(session)
        log.push(item("system", "session", save_named_session(session, name)))
        return true
    }
    if line.starts_with("/load ") {
        let name = line.replace("/load ", "").trim()
        let loaded = load_named_session(name)
        if loaded == nil {
            log.push(item("system", "session", "load failed: " + name))
            return true
        }
        session.messages = loaded.messages
        save_session(session)
        restore_log(log, session, "loaded session " + name)
        return true
    }
    if line.starts_with("/self ") {
        let goal = line.replace("/self ", "")
        log.push(item("system", "self-prompt", seed_self_prompt(goal, 100)))
        return true
    }
    if line == "/self-stop" || line == "/stop-self" {
        log.push(item("system", "self-prompt", stop_self_prompt()))
        return true
    }
    if line == "/self-budget" {
        log.push(item("system", "self-prompt", "self-prompt budget=" + str(read_self_prompt_budget())))
        return true
    }
    if line.starts_with("/self-budget ") {
        let raw = line.replace("/self-budget ", "")
        log.push(item("system", "self-prompt", set_self_prompt_budget_text(raw)))
        return true
    }
    if line == "/self-pause" {
        log.push(item("system", "self-prompt", pause_self_prompt()))
        return true
    }
    if line == "/self-resume" {
        log.push(item("system", "self-prompt", resume_self_prompt()))
        return true
    }
    if line.starts_with("/next ") {
        let feature = line.replace("/next ", "")
        log.push(item("system", "next", write_next_feature(feature)))
        return true
    }
    if line == "/next" {
        log.push(item("system", "next", read_next_feature()))
        return true
    }
    if line == "/timeline" {
        log.push(item("system", "timeline", timeline_text(session)))
        return true
    }
    if line == "/bookmarks" {
        log.push(item("system", "bookmarks", list_bookmarks()))
        return true
    }
    if line == "/bookmarks-clear" {
        log.push(item("system", "bookmarks", clear_bookmarks()))
        return true
    }
    if line == "/events" {
        log.push(item("system", "events", recent_events()))
        return true
    }
    if line == "/events-clear" {
        log.push(item("system", "events", clear_events()))
        return true
    }
    if line.starts_with("/bookmark ") {
        let label = line.replace("/bookmark ", "")
        log.push(item("system", "bookmark", add_bookmark(session, label)))
        return true
    }
    if line == "/bookmark" {
        log.push(item("system", "bookmark", add_bookmark(session, "bookmark")))
        return true
    }
    if line.starts_with("/search ") {
        let query = line.replace("/search ", "")
        log.push(item("system", "search", search_session(session, query)))
        return true
    }
    if line == "/last" {
        log.push(item("system", "last", last_output(session)))
        return true
    }
    if line == "/last-agent" {
        log.push(item("system", "last-agent", last_message_by_role(session, "assistant")))
        return true
    }
    if line == "/last-tool" {
        log.push(item("system", "last-tool", last_message_by_role(session, "tool")))
        return true
    }
    if line == "/retry-tool" {
        log.push(item("system", "retry", retry_last_tool(log, session)))
        return true
    }
    if line == "/compact" {
        log.push(item("system", "compact", compact_session(log, session)))
        return true
    }
    if line == "/templates" {
        log.push(item("system", "templates", prompt_templates()))
        return true
    }
    if line.starts_with("/use ") {
        let raw = line.replace("/use ", "")
        let parts = raw.split(" ")
        let name = parts[0]
        let rest = raw.replace(name, "").trim()
        return send_prompt(log, session, reload_state(), template_prompt(name, rest))
    }
    if line == "/checkpoints" {
        log.push(item("system", "checkpoints", checkpoint_names()))
        return true
    }
    if line.starts_with("/restore ") {
        let path = line.replace("/restore ", "")
        log.push(item("system", "restore", restore_checkpoint(path)))
        return true
    }
    if line.starts_with("/export ") {
        let name = line.replace("/export ", "")
        log.push(item("system", "export", export_session(session, name)))
        return true
    }
    if line == "/export" {
        log.push(item("system", "export", export_session(session, "agent_tui_transcript")))
        return true
    }
    return false
}
fn search_session(session, query) {
    let needle = query.trim()
    if needle == "" { return "usage: /search <text>" }
    let hits = []
    let mut i = 0
    for message in session.messages {
        let role = arg(message, "role", "message")
        let content = single_line(arg(message, "content", ""))
        if content.contains(needle) || role.contains(needle) {
            hits.push(str(i) + ". " + role + ": " + take_text(content, 120))
        }
        i = i + 1
    }
    if hits.len() == 0 { return "no session hits for: " + needle }
    let mut start = 0
    if hits.len() > 12 { start = hits.len() - 12 }
    let recent = []
    let mut j = start
    while j < hits.len() {
        recent.push(hits[j])
        j = j + 1
    }
    return "search hits=" + str(hits.len()) + " for: " + needle + "\n" + recent.join("\n")
}
fn last_message_by_role(session, role) {
    let mut i = session.messages.len() - 1
    while i >= 0 {
        let message = session.messages[i]
        if type_of(message) == "map" && arg(message, "role", "") == role {
            return role + ": " + arg(message, "content", "")
        }
        i = i - 1
    }
    return "no recent " + role + " message"
}

fn last_output(session) {
    let tool = last_message_by_role(session, "tool")
    if !tool.starts_with("no recent") { return tool }
    return last_message_by_role(session, "assistant")
}
fn last_tool_call(session) {
    let mut i = session.messages.len() - 1
    while i >= 0 {
        let message = session.messages[i]
        if type_of(message) == "map" && message.contains("tool_calls") && message.tool_calls.len() > 0 {
            return message.tool_calls[message.tool_calls.len() - 1]
        }
        i = i - 1
    }
    return nil
}

fn retry_last_tool(log, session) {
    let call = last_tool_call(session)
    if call == nil { return "no previous model tool call to retry" }
    append_tool(log, session.messages, call)
    save_session(session)
    return "retried tool: " + call_name(call)
}
fn compact_summary(session) {
    return "Compacted prior session. " + timeline_text(session)
}

fn compact_session(log, session) {
    let old_count = session.messages.len()
    if old_count <= 16 { return "session small enough; no compaction needed" }
    let summary = map()
    summary.role = "system"
    summary.content = compact_summary(session)
    let kept = []
    let start = old_count - 12
    let mut i = start
    while i < old_count {
        kept.push(session.messages[i])
        i = i + 1
    }
    let messages = base_messages()
    messages.push(summary)
    for message in kept { messages.push(message) }
    session.messages = messages
    save_session(session)
    restore_log(log, session, "compacted session: " + str(old_count) + " -> " + str(session.messages.len()) + " messages")
    return "compacted session: " + str(old_count) + " -> " + str(session.messages.len()) + " messages"
}
fn prompt_template(name) {
    if name == "fix" { return "Inspect the relevant files, reproduce or identify the bug, make the smallest safe fix, run an appropriate check, and summarize the change." }
    if name == "test" { return "Inspect the project, identify the right test target, run the smallest useful test, fix failures if appropriate, and report results." }
    if name == "docs" { return "Inspect the relevant code or behavior, update documentation clearly, and verify formatting or links if possible." }
    if name == "refactor" { return "Inspect the current implementation, make a behavior-preserving refactor in small steps, run checks, and summarize risk." }
    if name == "release" { return "Inspect version/status, run checks, summarize changes, and prepare concise release notes."
    }
    return ""
}

fn prompt_templates() {
    return "templates: fix, test, docs, refactor, release"
}

fn template_prompt(name, rest) {
    let base = prompt_template(name)
    if base == "" { return prompt_templates() }
    if rest.trim() == "" { return base }
    return base + "\n\nTask: " + rest.trim()
}
fn workspace_health(reload) {
    let path = arg(reload, "path", script_path())
    let check = self_check(path)
    let status = "ok"
    if check != "" { status = "check failed: " + single_line(check) }
    let git = shell("git status --short", default_tool_timeout_ms())
    let git_text = "git unavailable"
    if git.is_ok() {
        let report = git.unwrap()
        git_text = arg(report, "stdout", "").trim()
        if git_text == "" { git_text = "clean" }
    }
    return "health: script=" + path + "; check=" + status + "\ngit:\n" + git_text
}
fn git_report(command) {
    let result = shell(command, default_tool_timeout_ms())
    if result.is_err() { return result.err() }
    let report = result.unwrap()
    let stdout = arg(report, "stdout", "").trim()
    let stderr = arg(report, "stderr", "").trim()
    let out = stdout
    if stderr != "" { out = out + "\n" + stderr }
    if out == "" { out = "ok" }
    return out
}

fn git_status_text() {
    return git_report("git status --short")
}

fn git_diff_text() {
    return git_report("git diff --stat") + "\n" + git_report("git diff --check")
}

fn git_commit_text(message) {
    let msg = message.trim()
    if msg == "" { return "usage: /git-commit <message>" }
    return git_report("git add agent_tui.tether tetherscript_agent_post.md; git commit --no-gpg-sign -m \"" + msg + "\"")
}
fn release_notes(session) {
    let mut body = "# Release notes for " + agent_label() + "\n\n"
    body = body + "## Summary\n\n"
    body = body + "- Messages: " + str(session.messages.len()) + "\n"
    body = body + "- Next feature: " + read_next_feature() + "\n"
    body = body + "- Tool timeout: " + str(default_tool_timeout_ms()) + " ms\n"
    body = body + "- Checkpoints: " + checkpoints_dir() + "\n\n"
    body = body + "## Recent timeline\n\n```text\n" + timeline_text(session) + "\n```\n\n"
    body = body + "## Git status\n\n```text\n" + git_status_text() + "\n```\n"
    return body
}

fn write_release_notes(session, name) {
    let clean = name.trim()
    if clean == "" { clean = "agent_tui_release_notes" }
    fs_mkdir(exports_dir())
    let path = exports_dir() + "/" + clean + ".md"
    let r = fs_write(path, release_notes(session))
    if r.is_err() { return "release notes failed: " + r.err() }
    return "wrote release notes to " + path
}
fn config_text() {
    return "config: version=" + agent_version() +
        "; model=" + default_model() +
        "; router=" + env_text("TETHERSCRIPT_AGENT_ROUTER") +
        "; mode=" + env_text("TETHERSCRIPT_AGENT_MODE") +
        "; stdio_rpc=" + env_text("TETHERSCRIPT_AGENT_STDIO_RPC") +
        "; timeout_ms=" + str(default_tool_timeout_ms()) +
        "; confirm_destructive=" + str(destructive_confirm_enabled()) +
        "; session=" + session_path() +
        "; sessions_dir=" + sessions_dir() +
        "; exports_dir=" + exports_dir() +
        "; checkpoints_dir=" + checkpoints_dir()
}
fn provider_diag_text() {
    if !provider_ready() { return provider_missing() }
    let desc = provider.describe()
    if desc.is_err() { return "provider describe failed: " + desc.err() }
    let info = desc.unwrap()
    return "provider: ready" +
        "; model=" + default_model() +
        "; endpoint=" + arg(info, "endpoint", "unknown") +
        "; router=" + env_text("TETHERSCRIPT_AGENT_ROUTER")
}
fn checklist_text(reload) {
    let provider = "missing"
    if provider_ready() { provider = "ready" }
    let check = self_check(arg(reload, "path", script_path()))
    let check_status = "ok"
    if check != "" { check_status = "failed" }
    return "startup checklist:" +
        " provider=" + provider +
        "; model=" + default_model() +
        "; check=" + check_status +
        "; session=" + str(fs_exists(session_path()).unwrap_or(false)) +
        "; next=" + read_next_feature() +
        "; self_budget=" + str(read_self_prompt_budget()) +
        "; timeout_ms=" + str(default_tool_timeout_ms()) +
        "; confirm_destructive=" + str(destructive_confirm_enabled())
}
fn changelog_path() {
    return ".tetherscript/agent_tui_changelog.md"
}

fn changelog_entry(text) {
    let body = "## " + agent_label() + "\n\n- " + text.trim() + "\n- Next: " + read_next_feature() + "\n\n"
    fs_mkdir(".tetherscript")
    let existing = fs_read(changelog_path()).unwrap_or("# agent_tui changelog\n\n")
    let r = fs_write(changelog_path(), existing + body)
    if r.is_err() { return "changelog failed: " + r.err() }
    return "wrote changelog entry to " + changelog_path()
}

fn changelog_recent() {
    let raw = fs_read(changelog_path())
    if raw.is_err() { return "no changelog yet" }
    return take_text(raw.unwrap(), 2400)
}
fn release_flow(session) {
    let check = self_check(script_path())
    if check != "" { return "release blocked: check failed: " + single_line(check) }
    let notes = write_release_notes(session, "agent_tui_release_notes")
    let reference = export_command_reference()
    let change = changelog_entry("Prepared release artifacts for " + agent_label())
    let git = git_diff_text()
    return "release flow complete\n" + notes + "\n" + reference + "\n" + change + "\n" + git
}
// Operator-facing help/status commands keep the TUI discoverable as it grows.
fn policy_text() {
    let destructive = "off"
    if destructive_confirm_enabled() { destructive = "on" }
    return "policy: destructive_confirm=" + destructive +
        "; set TETHERSCRIPT_AGENT_CONFIRM_DESTRUCTIVE=1 to require confirm=true for overwrite/replace/remove" +
        "; checkpoints=" + checkpoints_dir() +
        "; tool_timeout_ms=" + str(default_tool_timeout_ms()) +
        "; shell timeout override uses timeout_ms"
}
fn roadmap_text(session) {
    return "roadmap: " + agent_label() +
        "; self_budget=" + str(read_self_prompt_budget()) +
        "; paused=" + str(self_prompt_paused()) +
        "; next=" + read_next_feature() +
        "; messages=" + str(session.messages.len()) +
        "; sessions=" + sessions_dir() + "; checkpoints=" + checkpoints_dir() +
        "; upcoming=stale prompt cleanup, commit-ready cleanup, version bump"
}
fn command_reference() {
    return "# " + agent_label() + " command reference\n\n" +
        "## Palette\n\n```text\n" + command_palette() + "\n```\n\n" +
        "## Help\n\n```text\n" + command_help() + "\n```\n\n" +
        "## Examples\n\n```text\n" + command_examples() + "\n```\n"
}

fn export_command_reference() {
    fs_mkdir(exports_dir())
    let path = exports_dir() + "/agent_tui_command_reference.md"
    let r = fs_write(path, command_reference())
    if r.is_err() { return "command reference failed: " + r.err() }
    return "wrote command reference to " + path
}
fn command_palette() {
    return "palette:\n" +
        "core: /help /examples /status /config /provider /checklist /health /roadmap /policy\n" +
        "navigation: /up /down /bottom /timeline /search <text> /last /bookmark [label] /bookmarks\n" +
        "sessions: /save <name> /load <name> /sessions /compact /export [name] /release-notes [name]\n" +
        "tools: /tools /tool <cmd> /retry-tool /checkpoints /restore <path>\n" +
        "git: /git /git-diff /git-commit <msg>\n" +
        "automation: /self <goal> /next [feature] /templates /use <template> [task]"
}
fn tui_preview_text() {
    let rows = []
    rows.push(item("system", "preview", "box drawing, wrapping, and color sample"))
    rows.push(item("user", "you", "short prompt"))
    rows.push(item("agent", "provider", "This is a longer preview line that should wrap cleanly inside the frame and preserve readable indentation across wrapped rows."))
    rows.push(item("tool", "sample", "stdout line 1\nstdout line 2\nstdout line 3"))
    let view = map()
    view.title = agent_label() + " preview"
    view.width = 72
    view.height = 12
    view.status = "preview | /bottom exits scroll"
    view.items = rows
    view.scroll = 0
    return render_view(view)
}
fn command_examples() {
    return "examples:\n" +
        "/tool powershell Get-ChildItem\n" +
        "/tool browser_text html=<h1>Hello</h1> selector=h1\n" +
        "/use fix describe the bug here\n" +
        "/search provider\n" +
        "/bookmark important\n" +
        "/export demo-transcript\n" +
        "/git-diff\n" +
        "/next Add the next small feature"
}
fn command_help() {
    return "help: /palette groups commands; /examples shows usage; /status shows runtime state; /roadmap shows next work. autonomous: /self <goal>, /self-budget [n], /self-pause, /self-resume, /self-stop, /next [feature]. navigation: /up /down /bottom. exit: /quit"
}

fn command_status(session, reload, input) {
    let provider = "missing"
    if provider_ready() { provider = "ready" }
    return "version=" + agent_version() + "; provider=" + provider + "; model=" + default_model() + "; messages=" + str(session.messages.len()) + "; input=" + input_status(input) + "; scroll=" + str(arg(input, "scroll", 0)) + "; reload=" + str(reload.reloading) + "; timeout_ms=" + str(default_tool_timeout_ms()) + "; confirm_destructive=" + str(destructive_confirm_enabled()) + "; separators=" + separator_mode() + "; self_budget=" + str(read_self_prompt_budget()) + "; paused=" + str(self_prompt_paused()) + "; next=" + read_next_feature()
}
// Multiline prompt mode: collect lines until /send or /cancel.
fn multiline_start(log, input, line) {
    input.multiline = true
    input.lines = []
    if line.starts_with("/multi ") { input.lines.push(line.replace("/multi ", "")) }
    log.push(item("system", "input", "multiline started; /send submits, /cancel cancels"))
    return true
}

fn multiline_handle(log, session, reload, input, line) {
    if line == "/send" {
        input.multiline = false
        let prompt = input.lines.join("\n")
        input.lines = []
        if prompt.trim() == "" {
            log.push(item("system", "input", "empty multiline ignored"))
            return true
        }
        return send_prompt(log, session, reload, prompt)
    }
    if line == "/cancel" {
        input.multiline = false
        input.lines = []
        log.push(item("system", "input", "multiline canceled"))
        return true
    }
    input.lines.push(line)
    return true
}

fn normalize_command(line) {
    if line == "/h" { return "/help" }
    if line == "/?" { return "/help" }
    if line == "/q" { return "/quit" }
    if line == "/s" { return "/status" }
    if line == "/r" { return "/roadmap" }
    if line == "/p" { return "/provider" }
    if line == "/c" { return "/checklist" }
    if line == "/g" { return "/git" }
    if line == "/d" { return "/git-diff" }
    if line == "/b" { return "/bottom" }
    if line == "/u" { return "/up" }
    if line == "/j" { return "/down" }
    if line == "/t" { return "/timeline" }
    if line == "/l" { return "/last" }
    return line
}
// Dispatch one TUI input line: commands, manual tools, or normal agent prompt.
fn interactive_handle(log, session, reload, input, line) {
    if input.multiline { return multiline_handle(log, session, reload, input, line) }
    line = normalize_command(line)
    if line == "" { return true }
    if line == "/quit" { save_session(session); return false }
    if line == "/clear" {
        let fresh = clear_session()
        session.messages = fresh.messages
        while log.len() > 0 { log.pop() }
        log.push(item("system", "session", "cleared; type a prompt; /quit exits"))
        return true
    }
    if session_command(log, session, line) { return true }
    if line == "/up" {
        input.scroll = arg(input, "scroll", 0) + 5
        return true
    }
    if line == "/down" {
        input.scroll = arg(input, "scroll", 0) - 5
        if input.scroll < 0 { input.scroll = 0 }
        return true
    }
    if line == "/bottom" {
        input.scroll = 0
        return true
    }
    if line == "/help" {
        log.push(item("system", "help", command_help()))
        return true
    }
    if line == "/examples" {
        log.push(item("system", "examples", command_examples()))
        return true
    }
    if line == "/preview" {
        log.push(item("system", "preview", tui_preview_text()))
        return true
    }
    if line == "/command-reference" {
        log.push(item("system", "reference", export_command_reference()))
        return true
    }
    if line == "/palette" {
        log.push(item("system", "palette", command_palette()))
        return true
    }
    if line == "/status" {
        log.push(item("system", "status", command_status(session, reload, input)))
        return true
    }
    if line == "/config" {
        log.push(item("system", "config", config_text()))
        return true
    }
    if line == "/provider" {
        log.push(item("system", "provider", provider_diag_text()))
        return true
    }
    if line == "/checklist" {
        log.push(item("system", "checklist", checklist_text(reload)))
        return true
    }
    if line == "/health" {
        log.push(item("system", "health", workspace_health(reload)))
        return true
    }
    if line == "/git" || line == "/git-status" {
        log.push(item("system", "git", git_status_text()))
        return true
    }
    if line == "/git-diff" {
        log.push(item("system", "git", git_diff_text()))
        return true
    }
    if line.starts_with("/git-commit ") {
        let message = line.replace("/git-commit ", "")
        log.push(item("system", "git", git_commit_text(message)))
        return true
    }
    if line == "/release-notes" {
        log.push(item("system", "release", write_release_notes(session, "agent_tui_release_notes")))
        return true
    }
    if line == "/release" {
        log.push(item("system", "release", release_flow(session)))
        return true
    }
    if line == "/changelog" {
        log.push(item("system", "changelog", changelog_recent()))
        return true
    }
    if line.starts_with("/changelog ") {
        let text = line.replace("/changelog ", "")
        log.push(item("system", "changelog", changelog_entry(text)))
        return true
    }
    if line == "/version" {
        log.push(item("system", "version", agent_label()))
        return true
    }
    if line.starts_with("/bump ") {
        let part = line.replace("/bump ", "")
        log.push(item("system", "version", bump_version(part)))
        return true
    }
    if line.starts_with("/release-notes ") {
        let name = line.replace("/release-notes ", "")
        log.push(item("system", "release", write_release_notes(session, name)))
        return true
    }
    if line == "/roadmap" {
        log.push(item("system", "roadmap", roadmap_text(session)))
        return true
    }
    if line == "/tools" {
        log.push(item("system", "tools", "cwd, ls <path>, read <path>, replace path/old/new JSON, run|powershell|bash <command> or JSON timeout_ms, js <script>, browser_text|browser_query|browser_render JSON"))
        return true
    }
    if line == "/multi" || line.starts_with("/multi ") {
        return multiline_start(log, input, line)
    }
    if line.starts_with("/tool ") {
        let command = line.replace("/tool ", "")
        let output = manual_tool(command)
        log.push(item("tool", command, tool_log_text(command, output)))
        return true
    }
    input.scroll = 0
    return send_prompt(log, session, reload, line)
}

// Interactive terminal UI entrypoint.
fn interactive_main() {
    let saved = load_session()
    let log = initial_log(saved)
    let session = initial_session(saved)
    let reload = reload_state()
    let input = new_input()
    let mut resumed = load_self_prompt()
    let mut running = true
    print(ansi_enter())
    while running && resumed != "" {
        log.push(item("system", "self-prompt", "auto-prompting continuation"))
        running = send_prompt(log, session, reload, resumed)
        if running { resumed = load_self_prompt() } else { resumed = "" }
    }
    while running {
        present_at(log, status_with_hints(input), arg(input, "scroll", 0))
        let event = tui_read_event("> ")
        if event.is_err() {
            log.push(item("system", "input", event.err()))
            running = false
        } else {
            running = interactive_handle(log, session, reload, input, event.unwrap().text)
        }
    }
    if reload.reloading { present(log, "reloading") } else { present(log, "done") }
    print(ansi_leave())
}
// =============================================================================
//  PROGRAM ENTRYPOINTS
// =============================================================================

// JSON-RPC/MCP entrypoint for stdio clients.
fn rpc_main() {
    let saved = load_session()
    let log = initial_log(saved)
    let session = initial_session(saved)
    let reload = reload_state()
    let mut running = true
    while running {
        show(log, "waiting for rpc")
        let read = stdio_read()
        if read.is_err() {
            stdio_write(jsonrpc_error(nil, -32700, read.err()))
        } else {
            let msg = read.unwrap()
            if msg == nil { running = false } else { running = handle(log, session, reload, msg) }
        }
    }
    show(log, "done")
}

// Choose TUI mode by default, or JSON-RPC mode via environment variables.
fn main() {
    if env_text("TETHERSCRIPT_AGENT_MODE") == "rpc" { return rpc_main() }
    if env_text("TETHERSCRIPT_AGENT_STDIO_RPC") == "1" { return rpc_main() }
    interactive_main()
}
