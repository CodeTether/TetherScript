fn main() {
    let html = "<canvas id='gl' width='2' height='2'></canvas>"
    let script = "let gl=document.getElementById('gl').getContext('webgl');gl.clearColor(0.2,0.4,0.6,1);gl.clear(gl.COLOR_BUFFER_BIT);gl.getParameter(gl.RENDERER)+':'+gl.getParameter(gl.COLOR_CLEAR_VALUE).join(',');"
    println(browser_eval_js(html, script).value)
}
