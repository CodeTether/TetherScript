{
  "name": "tetherscript",
  "displayName": "tetherscript",
  "description": "Language support for tetherscript (.tether): syntax highlighting plus lex and parse diagnostics via LSP.",
  "version": "0.0.4",
  "publisher": "tetherscript-rs",
  "repository": {
    "type": "git",
    "url": "https://github.com/TetherScript-Rs/tetherscript"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:tetherscript"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tetherscript",
        "aliases": ["tetherscript"],
        "extensions": [".tether"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tetherscript",
        "scopeName": "source.tetherscript",
        "path": "./syntaxes/tetherscript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "tetherscript",
      "properties": {
        "tetherscript.serverPath": {
          "type": "string",
          "default": "tetherscript",
          "description": "Path to the `tetherscript` binary used to serve LSP. Must be on PATH or an absolute path."
        },
        "tetherscript.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP traffic between VSCode and tetherscript-lsp."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
