{
  "name": "tetherscript",
  "displayName": "tetherscript",
  "description": "Language support for tetherscript with module auto-imports, navigation, completion, and diagnostics.",
  "version": "0.0.10",
  "publisher": "tetherscript-rs",
  "repository": {
    "type": "git",
    "url": "https://github.com/TetherScript-Rs/tetherscript"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "test": "node test/run.js",
    "test:integration": "node test/integration/launch.js"
  },
  "activationEvents": [
    "onLanguage:tetherscript",
    "onCommand:tetherscript.runFile",
    "onCommand:tetherscript.runAgentTui",
    "onCommand:tetherscript.inspectTokens",
    "onCommand:tetherscript.inspectAst",
    "onCommand:tetherscript.inspectBytecode",
    "onCommand:tetherscript.startLsp",
    "onCommand:tetherscript.stopLsp",
    "onCommand:tetherscript.restartLsp"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tetherscript",
        "aliases": ["tetherscript"],
        "extensions": [".tether"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tetherscript",
        "scopeName": "source.tetherscript",
        "path": "./syntaxes/tetherscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tetherscript",
        "path": "./snippets/tetherscript.json"
      }
    ],
    "commands": [
      {
        "command": "tetherscript.runFile",
        "title": "Run File",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.runAgentTui",
        "title": "Run Agent TUI",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.inspectTokens",
        "title": "Show Tokens",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.inspectAst",
        "title": "Show AST",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.inspectBytecode",
        "title": "Show Bytecode",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.startLsp",
        "title": "Start Language Server",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.stopLsp",
        "title": "Kill Language Server",
        "category": "tetherscript"
      },
      {
        "command": "tetherscript.restartLsp",
        "title": "Restart Language Server",
        "category": "tetherscript"
      }
    ],
    "configuration": {
      "title": "tetherscript",
      "properties": {
        "tetherscript.serverPath": {
          "type": "string",
          "default": "tetherscript",
          "description": "Path to the `tetherscript` binary used to serve LSP. Must be on PATH or an absolute path."
        },
        "tetherscript.runArgs": {
          "type": "string",
          "default": "",
          "description": "Extra arguments inserted after `tetherscript run` for the Run File command, for example `--access-mode full`."
        },
        "tetherscript.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP traffic between VSCode and tetherscript-lsp."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}