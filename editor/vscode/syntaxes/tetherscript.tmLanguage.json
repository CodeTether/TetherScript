{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TetherScript",
  "scopeName": "source.tetherscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#fn-decl" },
    { "include": "#fn-call" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tetherscript",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.tetherscript",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.tetherscript",
          "match": "\\\\(n|t|r|\\\\|\"|0)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tetherscript",
          "match": "\\b(if|else|while|for|in|return|panic|move)\\b"
        },
        {
          "name": "storage.type.tetherscript",
          "match": "\\b(fn|let)\\b"
        },
        {
          "name": "storage.modifier.tetherscript",
          "match": "\\b(mut)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.tetherscript",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.tetherscript",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.tetherscript",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "fn-decl": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.tetherscript" },
        "2": { "name": "entity.name.function.tetherscript" }
      }
    },
    "fn-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.tetherscript" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.tetherscript",
          "match": "==|!=|<=|>=|&&|\\|\\||->|=>|[+\\-*/%<>=!&?]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tetherscript",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
